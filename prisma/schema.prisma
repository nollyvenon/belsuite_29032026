  emailsPerDay          Int       @default(1000000)
  
  // AI/ML Rate Limits
  aiTokensPerMinute     Int       @default(5000)
  aiTokensPerHour       Int       @default(500000)
  aiTokensPerDay        Int       @default(10000000)
  
  // Storage Limits (in GB)
