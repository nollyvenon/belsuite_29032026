// ── LEAD GENERATION ─────────────────────────────────────────────────────────

model LeadSource {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgLeadSources", fields: [organizationId], references: [id], onDelete: Cascade)

  name              String   @db.VarChar(128)
  sourceType        LeadSourceType // WEB_SCRAPE, IMPORT, MANUAL, API, LINKEDIN, etc.

  // Source configuration
  config            Json     // Source-specific settings (URLs, credentials, filters)
  isActive          Boolean  @default(true)

  // Tracking
  leadsGenerated    Int      @default(0)
  lastRunAt         DateTime?
  successRate       Float    @default(0) // 0-100%

  // Rate limiting & quotas
  dailyLimit        Int      @default(100)
  monthlyLimit      Int      @default(3000)
  monthlyUsage      Int      @default(0)

  leads             Lead[] @relation("SourceLeads")
  jobs              LeadGenJob[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([sourceType])
}

model Lead {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgLeads", fields: [organizationId], references: [id], onDelete: Cascade)

  // Core data
  firstName         String?  @db.VarChar(128)
  lastName          String?  @db.VarChar(128)
  email             String   @db.VarChar(255)
  phoneNumber       String?  @db.VarChar(20)
  company           String?  @db.VarChar(255)
  jobTitle          String?  @db.VarChar(128)
  industry          String?  @db.VarChar(128)
  companySize       String?  // "1-10", "10-50", "50-100", "100+"

  // Location
  city              String?  @db.VarChar(128)
  state             String?  @db.VarChar(128)
  country           String?  @db.VarChar(128)
  timezone          String?  @db.VarChar(64)

  // Source & enrichment
  sourceId          String?
  source            LeadSource? @relation("SourceLeads", fields: [sourceId], references: [id])
  enrichmentStatus  EnrichmentStatus @default(PENDING)
  enrichmentData    Json?   // Clearbit, Hunter, RocketReach responses
  verificationStatus VerificationStatus @default(UNVERIFIED)

  // Lead scoring & qualification
  leadScore         Int      @default(0) // 0-100
  leadGrade         LeadGrade @default(D) // A-F
  inboundScore      Int      @default(0) // Inbound engagement score

  // Engagement tracking
  visitorId         String?  // Links to VisitorTrack
  lastSeen          DateTime?
  pageViews         Int      @default(0)
  engagementValue   Float    @default(0)

  // CRM Integration
  contactId         String?
  contact           Contact? @relation("ContactLeads", fields: [contactId], references: [id])
  status            LeadStatus @default(NEW)
  tags              String[] // Searchable tags array
  notes             String?  @db.Text

  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastEngagedAt     DateTime?

  // Relations
  campaigns         CampaignRecipient[]
  activities        Activity[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([status])
  @@index([leadScore])
  @@index([createdAt])
}

model LeadGenJob {
  id                String   @id @default(cuid())
  sourceId          String
  source            LeadSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  status            JobStatus @default(PENDING)
  progress          Int      @default(0) // 0-100%
  leadsGenerated    Int      @default(0)
  leadsEnriched     Int      @default(0)

  startedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?  @db.Text

  createdAt         DateTime @default(now())

  @@index([sourceId])
  @@index([status])
}

model VisitorTrack {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgVisitors", fields: [organizationId], references: [id], onDelete: Cascade)

  anonymousId       String   @db.VarChar(255)
  email             String?  @db.VarChar(255)

  // Visitor info
  ipAddress         String?  @db.VarChar(45)
  userAgent         String?  @db.Text
  referrer          String?  @db.Text
  geoData           Json?    // Country, city, lat/lng

  // Pages visited
  pages             String[] // URLs
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @updatedAt
  sessionCount      Int      @default(1)
  totalTimeSeconds  Int      @default(0)

  // Conversion
  converted         Boolean  @default(false)
  conversionValue   Float    @default(0)

  // Link to lead if identified
  leadId            String?
  lead              Lead?    @relation(fields: [leadId], references: [id])

  @@index([organizationId])
  @@index([anonymousId])
  @@index([email])
}

// ── SEO & CONTENT ───────────────────────────────────────────────────────────

model BlogPost {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgBlogPosts", fields: [organizationId], references: [id], onDelete: Cascade)

  title             String   @db.VarChar(255)
  slug              String   @db.VarChar(255)
  content           String   @db.Text

  // SEO metadata
  metaDescription   String?  @db.VarChar(160)
  keywords          String[] // Target keywords
  focusKeyword      String?  @db.VarChar(128)

  // AI generation
  generationPrompt  String?  @db.Text
  aiModel           String?  // "gpt-4", "claude-3", etc.

  // Content metrics
  wordCount         Int      @default(0)
  readingTime       Int      @default(0) // minutes
  seoScore          Int      @default(0) // 0-100

  // Publishing
  status            ContentStatus @default(DRAFT)
  publishedAt       DateTime?
  scheduledFor      DateTime?

  // Analytics
  views             Int      @default(0)
  clicks            Int      @default(0)
  conversions       Int      @default(0)
  ranking           String?  // Current SERP position

  // Internal linking
  internalLinks     String[] // URLs
  backlinkCount     Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  backlinks         Backlink[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([publishedAt])
}

model Backlink {
  id                String   @id @default(cuid())
  postId            String
  post              BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  organizationId    String

  sourceUrl         String   @db.Text
  sourceTitle       String?  @db.VarChar(255)
  sourceDomain      String   @db.VarChar(255)
  anchorText        String?  @db.VarChar(255)

  // Quality metrics
  domainAuthority   Int?     // 1-100 (Moz DA)
  pageAuthority     Int?     // 1-100 (Moz PA)
  trustFlow         Int?     // Majestic TF
  citationFlow      Int?     // Majestic CF
  spamScore         Int?     // 0-100% spam

  // Status
  status            BacklinkStatus @default(PENDING)
  acquiredAt        DateTime?

  createdAt         DateTime @default(now())

  @@index([organizationId])
  @@index([status])
  @@index([domainAuthority])
}

model KeywordCluster {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgKeywordClusters", fields: [organizationId], references: [id], onDelete: Cascade)

  name              String   @db.VarChar(128)
  primaryKeyword    String   @db.VarChar(255)

  // Keywords in cluster
  keywords          String[] // ["seo tips", "how to rank", "seo guide"]

  // Metrics
  searchVolume      Int      @default(0) // monthly
  keywordDifficulty Int      @default(0) // 0-100
  suggestedBid      Float    @default(0) // For PPC

  // Content mapping
  postId            String?
  post              BlogPost? @relation(fields: [postId], references: [id])

  // Status
  status            ClusterStatus @default(RESEARCH)

  createdAt         DateTime @default(now())

  @@index([organizationId])
  @@index([primaryKeyword])
}

// ── CRM ──────────────────────────────────────────────────────────────────────

model Contact {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgContacts", fields: [organizationId], references: [id], onDelete: Cascade)

  firstName         String?  @db.VarChar(128)
  lastName          String?  @db.VarChar(128)
  email             String   @db.VarChar(255)
  phoneNumber       String?  @db.VarChar(20)
  company           String?  @db.VarChar(255)
  jobTitle          String?  @db.VarChar(128)

  // Linked leads
  leads             Lead[] @relation("ContactLeads")

  // Deal associations
  deals             Deal[] @relation("DealContacts")

  // Engagement
  score             Int      @default(0)
  source            String?  @db.VarChar(128)
  status            ContactStatus @default(ACTIVE)
  tags              String[]

  // Activity
  lastInteraction   DateTime?
  activities        Activity[]

  // Custom fields
  customFields      Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([status])
}

model Deal {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgDeals", fields: [organizationId], references: [id], onDelete: Cascade)

  title             String   @db.VarChar(255)
  description       String?  @db.Text

  // Financial
  amount            Float
  currency          String   @default("USD")
  expectedRevenue   Float?   // amount * probability

  // Pipeline
  stage             DealStage @default(LEAD) // LEAD, QUALIFIED, PROPOSAL, NEGOTIATION, WON, LOST
  probability       Int      @default(0)    // 0-100%

  // Contacts & ownership
  contacts          Contact[] @relation("DealContacts")
  ownerId           String?
  owner             User? @relation("UserDeals", fields: [ownerId], references: [id])

  // Dates
  expectedCloseDate DateTime?
  wonAt             DateTime?
  lostAt            DateTime?

  // Activity
  activities        Activity[]
  notes             String?  @db.Text
  lastActivityAt    DateTime?

  // Automation
  isAutomated       Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([stage])
  @@index([probability])
}

model Activity {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgActivities", fields: [organizationId], references: [id], onDelete: Cascade)

  type              ActivityType // CALL, EMAIL, SMS, MEETING, NOTE, WEB_ACTIVITY

  // Subject
  leadId            String?
  lead              Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId            String?
  deal              Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Details
  title             String   @db.VarChar(255)
  description       String?  @db.Text
  duration          Int?     // seconds

  // Outreach data
  channel           String?  // "email", "phone", "sms", "LinkedIn"
  status            ActivityStatus @default(PLANNED)
  result            String?  // "positive", "neutral", "negative"

  // Assignment
  assignedTo        String?
  user              User? @relation("UserActivities", fields: [assignedTo], references: [id])

  // Scheduling
  scheduledFor      DateTime?
  completedAt       DateTime?

  // AI & automation
  aiGenerated       Boolean  @default(false)
  automationJobId   String?

  createdAt         DateTime @default(now())

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([leadId])
  @@index([contactId])
  @@index([dealId])
}

