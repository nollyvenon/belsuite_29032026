// --- UGC Project -------------------------------------------------------------

model UGCProject {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation("OrgUGCProjects", fields: [organizationId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User             @relation("UserUGCProjects", fields: [createdById], references: [id])

  title           String           @db.VarChar(255)
  description     String?          @db.Text

  // Brand voice context (JSON: tone, personality, keywords, cta, etc.)
  brandContext    String?          @db.Text

  // Avatar
  avatarId        String?
  avatar          UGCAvatar?       @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  // Voice clone
  voiceCloneId    String?
  voiceClone      VoiceClone?      @relation(fields: [voiceCloneId], references: [id], onDelete: SetNull)

  status          UGCProjectStatus @default(DRAFT)

  // Script
  script          UGCScript?

  // Renders
  renders         UGCRender[]

  // Output settings
  aspectRatio     String           @db.VarChar(16) @default("9:16")
  durationSeconds Int?
  platform        String?          @db.VarChar(64)   // tiktok, instagram, youtube, etc.

  // Final output
  outputUrl       String?          @db.Text
  thumbnailUrl    String?          @db.Text

  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

// --- Deal (HubSpot-replacement: Revenue-attached opportunities) ---------------

enum DealStage {
  PROSPECTING
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum DealPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Deal {
  id              String       @id @default(cuid())
  organizationId  String
  userId          String
  title           String       @db.VarChar(255)
  contactEmail    String?      @db.VarChar(255)
  contactName     String?      @db.VarChar(255)
  companyName     String?      @db.VarChar(255)
  stage           DealStage    @default(PROSPECTING)
  priority        DealPriority @default(MEDIUM)
  value           Float        @default(0)
  currency        String       @db.VarChar(8) @default("USD")
  probability     Int          @default(20)
  expectedCloseAt DateTime?
  closedAt        DateTime?
  ownerId         String?
  sourceLeadId    String?
  pipelineName    String       @db.VarChar(128) @default("Sales")
  lostReason      String?      @db.VarChar(255)
  tags            String?      @db.Text
  notes           String?      @db.Text
  aiScore         Int?
  aiNotes         String?      @db.Text
  properties      String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  activities      ContactActivity[]

  @@index([organizationId, stage])
  @@index([organizationId, ownerId])
  @@index([organizationId, expectedCloseAt])
}

// --- Contact Activity Timeline -----------------------------------------------

enum ActivityType {
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_CLICKED
  CALL_MADE
  CALL_RECEIVED
  NOTE_ADDED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  MEETING_SCHEDULED
  FORM_SUBMITTED
  PAGE_VISITED
  TASK_CREATED
  TASK_COMPLETED
  SMS_SENT
  SEQUENCE_ENROLLED
}

model ContactActivity {
  id              String       @id @default(cuid())
  organizationId  String
  contactEmail    String       @db.VarChar(255)
  contactName     String?      @db.VarChar(255)
  activityType    ActivityType
  dealId          String?
  deal            Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  subject         String?      @db.VarChar(512)
  body            String?      @db.Text
  metadata        String?      @db.Text
  performedBy     String?      @db.VarChar(255)
  createdAt       DateTime     @default(now())

  @@index([organizationId, contactEmail])
  @@index([organizationId, activityType])
  @@index([organizationId, createdAt])
  @@index([dealId])
}

// --- Keyword Rank Tracking (Ahrefs-replacement) ------------------------------

model KeywordRank {
  id              String   @id @default(cuid())
  organizationId  String
  keyword         String   @db.VarChar(512)
  domain          String   @db.VarChar(255)
  position        Int?
  previousPos     Int?
  searchVolume    Int?
  difficulty      Int?
  url             String?  @db.VarChar(2048)
  country         String   @db.VarChar(8) @default("us")
  device          String   @db.VarChar(16) @default("desktop")
  features        String?  @db.Text
  trackedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([organizationId, keyword])
  @@index([organizationId, domain])
  @@index([organizationId, trackedAt])
}

// --- Inbound Call (Call Center replacement) ----------------------------------

enum InboundCallStatus {
  RINGING
  ANSWERED
  MISSED
  VOICEMAIL
  TRANSFERRED
  COMPLETED
}

model InboundCall {
  id              String            @id @default(cuid())
  organizationId  String
  fromNumber      String            @db.VarChar(64)
  toNumber        String            @db.VarChar(64)
  callerName      String?           @db.VarChar(255)
  status          InboundCallStatus @default(RINGING)
  agentId         String?
  queueName       String?           @db.VarChar(128)
  durationSeconds Int               @default(0)
  recordingUrl    String?           @db.Text
  transcription   String?           @db.Text
  aiSummary       String?           @db.Text
  sentiment       String?           @db.VarChar(32)
  tags            String?           @db.Text
  notes           String?           @db.Text
  externalCallId  String?           @db.VarChar(255)
  answeredAt      DateTime?
  endedAt         DateTime?
  createdAt       DateTime          @default(now())

  @@index([organizationId, status])
  @@index([organizationId, agentId])
  @@index([organizationId, createdAt])
  @@index([fromNumber])
}

// --- Referral Engine ---------------------------------------------------------

enum ReferralStatus {
  PENDING
  SIGNED_UP
  CONVERTED
  PAID
  EXPIRED
}

model ReferralLink {
  id              String     @id @default(cuid())
  organizationId  String
  referrerId      String
  code            String     @unique @db.VarChar(64)
  campaignName    String?    @db.VarChar(128)
  rewardType      String     @db.VarChar(32) @default("credit")
  rewardValue     Float      @default(0)
  maxUses         Int?
  totalClicks     Int        @default(0)
  totalSignups    Int        @default(0)
  totalConverted  Int        @default(0)
  expiresAt       DateTime?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  referrals       Referral[]

  @@index([organizationId, referrerId])
  @@index([code])
}

model Referral {
  id              String         @id @default(cuid())
  organizationId  String
  linkId          String
  link            ReferralLink   @relation(fields: [linkId], references: [id], onDelete: Cascade)
  referredEmail   String?        @db.VarChar(255)
  referredUserId  String?
  status          ReferralStatus @default(PENDING)
  ipAddress       String?        @db.VarChar(64)
  userAgent       String?        @db.Text
  rewardPaid      Float          @default(0)
  convertedAt     DateTime?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())

  @@index([organizationId, linkId])
  @@index([organizationId, status])
  @@index([referredEmail])
}

// --- UGC Script ---------------------------------------------------------------

model UGCScript {
  id              String     @id @default(cuid())
  projectId       String     @unique
  project         UGCProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  content         String     @db.Text

  // AI generation info
  aiGenerated     Boolean    @default(false)
  prompt          String?    @db.Text
  model           String?    @db.VarChar(128)

  // Scene breakdown (JSON array of { text, durationHint, visualNote })
  scenesJson      String?    @db.Text

  wordCount       Int?
  estimatedSecs   Int?
  version         Int        @default(1)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([projectId])
}

// --- UGC Render ---------------------------------------------------------------

model UGCRender {
  id              String      @id @default(cuid())
  projectId       String
  project         UGCProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status          RenderStatus @default(QUEUED)

  // Provider job tracking
  provider        String      @db.VarChar(64) @default("heygen")
  externalJobId   String?     @db.VarChar(255)

  // Progress
  progress        Int         @default(0)  // 0-100

  // Output
  videoUrl        String?     @db.Text
  thumbnailUrl    String?     @db.Text
  durationSeconds Float?
  fileSizeBytes   BigInt?

  // Render config snapshot
  settingsJson    String?     @db.Text

  errorMessage    String?     @db.Text

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// MODULE 11: TEAMS & COLLABORATION
// ============================================================================

enum TeamRole {
  OWNER        // Full control, billing, team management
  ADMIN        // Manage team, users, permissions (no billing)
  EDITOR       // Create, edit, publish content
  CONTRIBUTOR  // Create content, cannot publish
  VIEWER       // Read-only access
  APPROVER     // Approve/reject content
}

enum ApprovalStatus {
  PENDING       // Awaiting approval
  APPROVED      // Approved by required approvers
  REJECTED      // Rejected with reason
  REVOKED       // Approval revoked by approver
  EXPIRED       // Approval expired
  CANCELLED     // Workflow cancelled before completion
}

enum TeamInvitationStatus {
  PENDING       // Invitation sent, awaiting acceptance
  ACCEPTED      // User accepted and joined team
  DECLINED      // User declined invitation
  REVOKED       // Admin revoked invitation
  EXPIRED       // Invitation expired
}

// ─── Teams ───────────────────────────────────────────────────────────────

model Team {
  id                String              @id @default(cuid())
  organizationId    String
  organization      Organization        @relation("OrgTeams", fields: [organizationId], references: [id], onDelete: Cascade)
  
  name              String              @db.VarChar(255)
  slug              String              @db.VarChar(128)
  description       String?             @db.Text
  
  // Access control
  isPublic          Boolean             @default(false)
  requiresApproval  Boolean             @default(true)   // Require approval workflows for content
  
  // Members & quota
  memberCount       Int                 @default(1)
  maxMembers        Int?                // Null = unlimited
  
  // Metadata
  metadata          String?             @db.Text         // JSON additional metadata
  
  // Owner / creator
  createdById       String
  createdBy         User                @relation("TeamCreator", fields: [createdById], references: [id])
  
  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  archivedAt        DateTime?           // Soft delete
  
  // Relations
  members           TeamMember[]
  invitations       TeamInvitation[]
  workflows         TeamWorkflow[]
  auditLogs         TeamAuditLog[]
  
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdById])
  @@index([createdAt])
  @@index([archivedAt])
}

// ─── Team Members ────────────────────────────────────────────────────────

model TeamMember {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User                @relation("TeamMember", fields: [userId], references: [id], onDelete: Cascade)
  
  role              TeamRole            @default(CONTRIBUTOR)
  
  // Status
  isActive          Boolean             @default(true)
  joinedAt          DateTime            @default(now())
  invitedAt         DateTime?           // When invited
  invitedBy         String?             // User ID who invited
  
  // Permissions cache (denormalized for performance)
  permissions       String[]            @default([])     // JSON array of permission strings
  
  // Last activity
  lastActivityAt    DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
}

// ─── Team Invitations ────────────────────────────────────────────────────

model TeamInvitation {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  // Invitee details
  invitedEmail      String              @db.VarChar(255)
  role              TeamRole            @default(CONTRIBUTOR)
  
  // Invitation metadata
  invitedBy         String
  invitedByUser     User                @relation("TeamInvited", fields: [invitedBy], references: [id])
  
  // Token & expiry
  token             String              @unique
  expiresAt         DateTime
  
  // Status & response
  status            TeamInvitationStatus @default(PENDING)
  acceptedAt        DateTime?
  acceptedByUserId  String?
  declinedAt        DateTime?
  revokedAt         DateTime?
  
  // Metadata
  message           String?             @db.Text
  
  createdAt         DateTime            @default(now())
  
  @@unique([teamId, invitedEmail])
  @@index([teamId])
  @@index([invitedEmail])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// ─── Team Workflows (Approval Workflows) ──────────────────────────────────

model TeamWorkflow {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  name              String              @db.VarChar(255)
  description       String?             @db.Text
  
  // Workflow configuration
  requiresApprovals Boolean             @default(true)
  requiredApprovals Int                 @default(1)      // Minimum approvals needed
  allowRejectReason Boolean             @default(true)
  
  // Applicable content types (JSON array: video, post, article, etc.)
  applicableContentTypes String[]       @default([])
  
  // Status
  isActive          Boolean             @default(true)
  
  // Trigger & notification config
  triggerConfig     String?             @db.Text         // JSON: triggers for auto-start
  notificationConfig String?            @db.Text         // JSON: notification settings
  
  // Statistics
  totalSubmissions  Int                 @default(0)
  approvedCount     Int                 @default(0)
  rejectedCount     Int                 @default(0)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  approvals         WorkflowApproval[]
  
  @@index([teamId])
  @@index([isActive])
}

// ─── Workflow Approvals (Approval Instances) ──────────────────────────────

model WorkflowApproval {
  id                String              @id @default(cuid())
  workflowId        String
  workflow          TeamWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  // Content being approved
  contentId         String              @db.VarChar(255)  // Content ID (video, post, article)
  contentType       String              @db.VarChar(128)  // Type of content
  
  // Submitter
  submittedById      String
  submittedBy       User                @relation("ApprovalSubmitter", fields: [submittedById], references: [id])
  
  // Status & reason
  status            ApprovalStatus      @default(PENDING)
  comments          String?             @db.Text         // Internal comments
  rejectionReason   String?             @db.Text         // If rejected
  
  // Approval chain
  requiredApprovals Int                 @default(1)
  receivedApprovals Int                 @default(0)
  
  // Versioning
  version           Int                 @default(1)      // Content version being approved
  contentSnapshot   String?             @db.Text         // JSON snapshot of content
  
  // Timestamps
  submittedAt       DateTime            @default(now())
  dueAt             DateTime?           // Optional deadline
  expiresAt         DateTime?           // Approval expires
  approvedAt        DateTime?
  rejectedAt        DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  approvals         Approval[]
  
  @@index([workflowId])
  @@index([contentId])
  @@index([submittedById])
  @@index([status])
  @@index([submittedAt])
  @@index([expiresAt])
}

// ─── Individual Approvals (One approval per approver per request) ────────

model Approval {
  id                String              @id @default(cuid())
  approvalRequestId String
  approvalRequest   WorkflowApproval    @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  
  // Approver
  approverId        String
  approver          User                @relation("Approver", fields: [approverId], references: [id])
  
  // Decision
  decision          String              @db.VarChar(32)   // APPROVED, REJECTED, or null for pending
  decisionReason    String?             @db.Text
  
  // Timestamps
  requestedAt       DateTime            @default(now())
  respondedAt       DateTime?
  expiresAt         DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([approvalRequestId, approverId])
  @@index([approvalRequestId])
  @@index([approverId])
  @@index([decision])
  @@index([expiresAt])
}

// ─── Team Audit Log (Immutable event log) ────────────────────────────────

model TeamAuditLog {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  // Actor
  userId            String
  user              User                @relation("TeamAuditActor", fields: [userId], references: [id])
  
  // Event details
  action            String              @db.VarChar(128)  // e.g., "member.added", "content.approved"
  resourceType      String              @db.VarChar(128)  // e.g., "team", "member", "approval"
  resourceId        String?
  
  // Changes/details
  changes           String?             @db.Text         // JSON: before/after values
  details           String?             @db.Text         // JSON: additional context
  
  // Request context
  ipAddress         String?
  userAgent         String?
  
  // Immutable timestamp
  timestamp         DateTime            @default(now())
  
  @@index([teamId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([resourceType])
}

// ─── Extend Organization model with team relations ───────────────────────
// Note: Organization model above already includes the relation:
// - teams               Team[]
// - This is added here for reference in the migration

// ============================================================================
// AI CEO MODULE - Autonomous Business Intelligence
// ============================================================================

// AI CEO Decision Model - Stores autonomous decisions and recommendations
model AIceoDecision {
  id            String   @id @default(cuid())
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Decision metadata
  type          String   // REVENUE_OPTIMIZATION, PRICING_ADJUSTMENT, CHURN_MITIGATION, FEATURE_RECOMMENDATION, GROWTH_STRATEGY
  severity      String   // low, medium, high, critical
  title         String
  description   String   @db.Text

  // AI-generated recommendation
  recommendation  String  @db.Text
  implementationSteps Json // Array of strings

  // Impact analysis
  estimatedImpact Json // { metric: string, currentValue: number, projectedValue: number, percentChange: number }
  actualImpact    Json? // { metric: string, actualValue: number, percentChange: number }

  // Confidence and model info
  confidence    Float    @default(0.75) // 0-1
  aiModel       String   @default("gpt-4-turbo")

  // Implementation tracking
  implemented   Boolean  @default(false)
  implementedAt DateTime?

  // Lifecycle
  generatedAt   DateTime @default(now())
  expiresAt     DateTime // Decision validity period

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([severity])
  @@index([expiresAt])
  @@index([implemented])
}

// AI CEO Report Model - Stores periodic executive reports
model AICEOReport {
  id            String   @id @default(cuid())
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Report metadata
  frequency     String   // daily, weekly, monthly
  period        Json     // { start: DateTime, end: DateTime }

  // Metrics snapshot
  metrics       Json     // { revenue, churn, pricing, features, growth }

  // AI summary
  summary       Json     // { keyHighlights, mainChallenges, opportunities, recommendations }

  // Associated decisions
  decisions     Json     // Array of decision IDs or full decision objects

  // Model and timestamps
  aiModel       String   @default("gpt-4-turbo")
  generatedAt   DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId])
  @@index([frequency])
  @@index([generatedAt])
}

// AI CEO Configuration Model - Stores org-specific settings
model AICEOConfig {
  id            String   @id @default(cuid())
  organizationId String   @unique
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Enable/disable AI CEO
  enabled       Boolean  @default(false)

  // Analysis preferences
  riskTolerance String   @default("balanced") // conservative, balanced, aggressive
  growthTarget  Float    @default(1.2) // 20% growth target by default

  // Churn tolerance
  maxChurnRate  Float    @default(5) // % acceptable churn rate

  // Analysis frequency
  analysisFrequency String @default("weekly") // daily, weekly, monthly

  // Notification settings
  sendNotifications Boolean @default(true)
  notificationEmail String?

  // Report settings
  autoGenerateReports Boolean @default(true)
  reportFrequency String   @default("weekly")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId])
  @@index([enabled])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI GATEWAY — Model Registry, Request Log, Budget, Health, Feature Assignments
// ─────────────────────────────────────────────────────────────────────────────

// Catalogue of AI models available to the gateway
model AIGatewayModel {
  id          String @id @default(cuid())
  provider    String // OPENAI | CLAUDE | GEMINI | LOCAL
  modelId     String // exact API identifier (e.g. "gpt-4o", "claude-sonnet-4-6")
  displayName String
  description String @default("")

  // Capability tags (text | image_generation | code | audio | embedding | moderation …)
  capabilities   String[]
  assignedFeatures String[] @default([])

  // Pricing — USD per token
  costPerInputToken  Float @default(0)
  costPerOutputToken Float @default(0)

  // Scoring (0–1)
  qualityScore Float @default(0.5)
  speedScore   Float @default(0.5)

  // Context limits
  contextWindow    Int @default(4096)
  maxOutputTokens  Int @default(1024)

  // Runtime config
  rateLimitPerMinute Int     @default(60)
  supportsStreaming  Boolean @default(true)
  supportsImages     Boolean @default(false)
  isEnabled          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  requests            AIGatewayRequest[]
  health              AIProviderHealth?
  featureAssignments  AIFeatureModelAssignment[] @relation("PrimaryModel")
  fallbackAssignments AIFeatureModelAssignment[] @relation("FallbackModel")

  @@unique([provider, modelId])
  @@index([provider])
  @@index([isEnabled])
}

// Every AI call routed through the gateway is logged here
model AIGatewayRequest {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  feature        String   // e.g. "content_studio", "ai_ads"
  taskType       String   // GatewayTask enum value
  provider       String
  modelId        String
  model          AIGatewayModel @relation(fields: [modelId], references: [id])

  // Token usage
  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  totalTokens  Int @default(0)

  // Cost
  costUsd Float @default(0)

  // Performance
  latencyMs Int @default(0)

  // Cache / failover flags
  cacheHit     Boolean @default(false)
  failoverUsed Boolean @default(false)
  failoverFrom String?  // first model that failed

  // Status
  success      Boolean @default(true)
  errorCode    String?
  errorMessage String? @db.Text

  // Dedup / audit
  promptHash String?  // SHA-256 of prompt (for cache key tracing)
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([modelId])
  @@index([feature])
  @@index([taskType])
  @@index([createdAt])
  @@index([success])
  @@index([cacheHit])
}

// Central task catalog for model orchestration (admin-defined)
model AITask {
  id          String  @id @default(cuid())
  taskKey     String  @unique // content_generation, image_generation, analytics_ai
  displayName String
  description String  @default("")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// Task-level routing rules with explicit primary/fallback model mapping
model AIRoutingRule {
  id                  String  @id @default(cuid())
  taskKey             String
  primaryModelId      String
  fallbackModelIds    String[] @default([])
  strategy            String   @default("balanced") // cheapest | fastest | best_quality | balanced | custom
  maxCostUsdPerRequest Float?
  maxLatencyMs        Int?
  qualityThreshold    Float?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([taskKey])
  @@index([isActive])
}

// Canonical AI usage ledger for cost, performance, and margin analytics
model AIUsageLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  taskKey        String
  featureKey     String
  provider       String
  modelRef       String
  requestId      String?
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  totalTokens    Int      @default(0)
  requestCostUsd Float    @default(0)
  requestRevenueUsd Float @default(0)
  marginUsd      Float    @default(0)
  latencyMs      Int      @default(0)
  success        Boolean  @default(true)
  errorCode      String?
  errorMessage   String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([taskKey])
  @@index([provider])
  @@index([modelRef])
  @@index([createdAt])
}

// Per-org, per-plan, or global spending caps.
// Resolution order (highest → lowest priority):
//   1. organizationId match (org-specific override)
//   2. planTier match      (e.g. FREE orgs all share one config)
//   3. global default      (organizationId IS NULL AND planTier IS NULL)
model AIBudgetConfig {
  id             String  @id @default(cuid())

  // Scope — at most one of these is set; both null = global default
  organizationId String?           // org-specific override
  planTier       String?           // FREE | STARTER | PROFESSIONAL | ENTERPRISE

  dailyLimitUsd      Float?
  monthlyLimitUsd    Float?
  perRequestLimitUsd Float?

  alertThresholdPct Float   @default(80)   // log warning at this % of limit
  blockOnExceed     Boolean @default(false) // hard-block when limit hit
  notifyEmail       String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, planTier])  // prevents duplicate scope entries
  @@index([organizationId])
  @@index([planTier])
  @@index([isActive])
}

// Rolling health metrics per model (persisted from in-memory circuit breakers)
model AIProviderHealth {
  id      String @id @default(cuid())
  modelId String @unique
  model   AIGatewayModel @relation(fields: [modelId], references: [id])

  isHealthy           Boolean @default(true)
  consecutiveFailures Int     @default(0)
  successRatePct      Float   @default(100)
  avgLatencyMs        Float   @default(0)
  p95LatencyMs        Float   @default(0)
  totalRequests       Int     @default(0)
  totalFailures       Int     @default(0)

  circuitBreakerState String  @default("CLOSED")  // CLOSED | OPEN | HALF_OPEN
  circuitOpenedAt     DateTime?
  nextRetryAt         DateTime?

  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  lastError     String?  @db.Text

  updatedAt DateTime @updatedAt

  @@index([isHealthy])
  @@index([circuitBreakerState])
}

// Maps a BelSuite feature to its primary (and optional fallback) AI model
model AIFeatureModelAssignment {
  id           String @id @default(cuid())
  feature      String @unique  // e.g. "content_studio", "ai_ads", "ugc_generator"
  featureLabel String @default("") // human-readable label

  primaryModelId  String
  primaryModel    AIGatewayModel  @relation("PrimaryModel",  fields: [primaryModelId],  references: [id])

  fallbackModelId String?
  fallbackModel   AIGatewayModel? @relation("FallbackModel", fields: [fallbackModelId], references: [id])

  // Routing overrides for this feature
  strategy           String  @default("balanced")  // cheapest | fastest | best_quality | balanced
  maxCostPerRequest  Float?
  maxLatencyMs       Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([feature])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI ASSISTANTS — Memory, Tasks, YouTube, Social Queue, Calendar
// ─────────────────────────────────────────────────────────────────────────────

enum AssistantType {
  SIERRA   // Executive strategy assistant
  DONNA    // Operations manager assistant
  YOUTUBE  // YouTube automation
  SOCIAL   // Social media assistant
  CALENDAR // Calendar & scheduling
}

// Conversation thread — one per session / topic
model AIConversation {
  id             String        @id @default(cuid())
  organizationId String
  userId         String?
  assistantType  AssistantType
  title          String?       // auto-generated from first message
  summary        String?       @db.Text // rolling summary for long threads
  isActive       Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AIMessage[]

  @@index([organizationId])
  @@index([assistantType])
  @@index([userId])
  @@index([isActive])
}

// Individual message within a conversation
model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // user | assistant | system | tool_result
  content        String         @db.Text
  metadata       Json?          // model, tokens, costUsd, taskId, etc.

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// Long-lived context per org + assistant (survives across conversations)
model AIAssistantContext {
  id             String        @id @default(cuid())
  organizationId String
  assistantType  AssistantType
  contextData    Json          // facts, preferences, goals, recent actions
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, assistantType])
  @@index([organizationId])
}

// Async tasks submitted by assistants (BullMQ-backed)
model AIAssistantTask {
  id             String        @id @default(cuid())
  organizationId String
  userId         String?
  assistantType  AssistantType
  taskType       String        // GENERATE_CONTENT | SCHEDULE_POST | SEND_DM | CREATE_EVENT | etc.
  status         String        @default("PENDING") // PENDING | PROCESSING | DONE | FAILED | CANCELLED
  priority       Int           @default(5)
  payload        Json
  result         Json?
  errorMessage   String?       @db.Text
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([taskType])
  @@index([assistantType])
  @@index([scheduledAt])
}

// YouTube end-to-end automation job
model YouTubeAutomationJob {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  topic          String
  targetAudience String?
  durationSecs   Int?

  // AI-generated outputs
  script            String?  @db.Text
  scriptApproved    Boolean  @default(false)
  seoTitle          String?
  seoDescription    String?  @db.Text
  seoTags           String[]
  thumbnailConcepts Json?    // array of concept objects

  // Upload tracking
  videoFilePath  String?
  videoUrl       String?
  youtubeVideoId String?
  publishAt      DateTime?
  status         String   @default("DRAFT")
  // DRAFT | SCRIPTING | SCRIPT_READY | SEO_DONE | UPLOADING | UPLOADED | PUBLISHED | FAILED

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([publishAt])
}

// Social media post/reply/DM queue
model SocialMediaQueueItem {
  id             String   @id @default(cuid())
  organizationId String
  platform       String   // TWITTER | INSTAGRAM | LINKEDIN | FACEBOOK | TIKTOK | YOUTUBE
  contentType    String   // POST | REPLY | DM | STORY | REEL
  content        String   @db.Text
  mediaUrls      String[]
  hashtags       String[]
  targetHandle   String?  // for replies / DMs
  parentPostId   String?  // platform post ID for replies
  scheduledAt    DateTime?
  publishedAt    DateTime?
  status         String   @default("QUEUED")
  // QUEUED | SCHEDULED | PUBLISHED | FAILED | CANCELLED
  engagementData Json?
  errorMessage   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([platform])
  @@index([status])
  @@index([scheduledAt])
}

// AI-managed calendar events (separate from user-created events)
model AICalendarEvent {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String?  @db.Text
  eventType      String   // CAMPAIGN | CONTENT | MEETING | REMINDER | DEADLINE | REVIEW
  startAt        DateTime
  endAt          DateTime?
  allDay         Boolean  @default(false)
  timezone       String   @default("UTC")
  reminders      Json?    // [{ minutesBefore: 30, method: "email" }]
  recurrence     Json?    // { frequency, interval, until, daysOfWeek }
  campaignId     String?
  isAIGenerated  Boolean  @default(true)
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([startAt])
  @@index([eventType])
  @@index([campaignId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATIONS — Connections, OAuth state, webhook log
// ─────────────────────────────────────────────────────────────────────────────

// Per-org connected integration with encrypted token storage
model IntegrationConnection {
  id             String @id @default(cuid())
  organizationId String
  provider       String // GOOGLE | FACEBOOK | TWITTER | LINKEDIN | TIKTOK | WHATSAPP | TELEGRAM | SMS_TWILIO | SMS_AFRICAS_TALKING
  providerUserId String? // user/page/channel ID at the provider

  // Encrypted tokens (AES-256-GCM, base64)
  accessToken     String?  @db.Text
  refreshToken    String?  @db.Text
  tokenExpiresAt  DateTime?

  // OAuth metadata
  scopes          String[] @default([])
  accountName     String?  // display name / page name
  accountEmail    String?
  accountAvatar   String?

  // Sub-account identifiers (e.g. Facebook Page ID, Twitter handle)
  accountId       String?
  accountHandle   String?
  metadata        Json?

  status          String   @default("ACTIVE") // ACTIVE | EXPIRED | REVOKED | ERROR
  lastUsedAt      DateTime?
  lastErrorAt     DateTime?
  lastError       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhooks        IncomingWebhookLog[]

  @@unique([organizationId, provider, accountId])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
}

// Short-lived OAuth state for CSRF protection during OAuth flows
model OAuthState {
  id             String @id @default(cuid())
  state          String @unique  // random nonce
  codeVerifier   String?         // PKCE verifier
  organizationId String
  userId         String?
  provider       String
  redirectUri    String?
  metadata       Json?           // extra params to carry through flow
  expiresAt      DateTime
  used           Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([state])
  @@index([expiresAt])
}

// ============================================================================
// CREDIT-BASED BILLING SYSTEM
// ============================================================================

// One wallet per organization — holds current credit balance
model CreditAccount {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  organization    Organization @relation("OrgCreditAccount", fields: [organizationId], references: [id], onDelete: Cascade)

  balanceCredits  Float    @default(0)        // current spendable balance
  lifetimeEarned  Float    @default(0)        // total credits ever added
  lifetimeSpent   Float    @default(0)        // total credits ever debited
  reservedCredits Float    @default(0)        // held for in-flight operations
  lowBalanceAlert Float?                       // notify at this threshold
  autoTopUpAt     Float?                       // auto purchase when balance drops here
  autoTopUpBundleId String?                    // which bundle to auto-buy

  transactions    CreditTransaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

// Immutable double-entry ledger for every credit movement
model CreditTransaction {
  id              String   @id @default(cuid())
  accountId       String
  account         CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organizationId  String

  type            CreditTxType
  amount          Float                        // positive = credit, negative = debit
  balanceAfter    Float                        // snapshot for audit trail
  description     String       @db.VarChar(255)
  metadata        Json?

  // References to source events
  usageRecordId   String?      @unique
  usageRecord     UsageRecord? @relation(fields: [usageRecordId], references: [id])
  paymentId       String?
  bundleId        String?
  bundle          CreditBundle? @relation(fields: [bundleId], references: [id])
  invoiceId       String?

  createdAt       DateTime @default(now())

  @@index([accountId])
  @@index([organizationId])
  @@index([type])
  @@index([createdAt])
}

enum CreditTxType {
  PURCHASE          // bought credits
  PLAN_ALLOCATION   // monthly credits from subscription plan
  USAGE_DEBIT       // consumed by a feature
  REFUND            // refunded credits
  ADJUSTMENT        // manual admin adjustment
  EXPIRY            // expired credits
  RESERVATION       // reserved for in-flight op
  RESERVATION_RELEASE
  BONUS             // free/promo credits
}

// Every measurable AI / feature usage event
model UsageRecord {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  feature         UsageFeature
  model           String?      @db.VarChar(128) // e.g. "gpt-4o", "claude-opus-4-6"
  provider        String?      @db.VarChar(64)  // e.g. "OPENAI", "ANTHROPIC"

  // Raw usage metrics
  inputTokens     Int?         @default(0)
  outputTokens    Int?         @default(0)
  totalTokens     Int?         @default(0)
  videoMinutes    Float?       @default(0)
  imageCount      Int?         @default(0)
  smsCount        Int?         @default(0)
  emailCount      Int?         @default(0)
  storageGb       Float?       @default(0)
  apiCalls        Int?         @default(1)

  // Cost accounting
  providerCostUsd Float        @default(0)  // what we paid the AI provider
  marginPct       Float        @default(0)  // markup applied
  creditsCost     Float        @default(0)  // credits charged to org
  usdEquivalent   Float        @default(0)  // USD value of credits charged

  // Tracing
  requestId       String?      @db.VarChar(128)
  conversationId  String?
  taskId          String?
  meta            Json?

  creditTransaction CreditTransaction?

  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([feature])
  @@index([model])
  @@index([createdAt])
  @@index([organizationId, feature, createdAt])
}

enum UsageFeature {
  AI_CHAT
  AI_CONTENT_GENERATION
  AI_SEO_ANALYSIS
  AI_LEAD_SCORING
  AI_EMAIL_DRAFT
  AI_SOCIAL_POST
  AI_IMAGE_GENERATION
  AI_IMAGE_EDIT
  AI_AUDIO_TRANSCRIPTION
  AI_EMBEDDING
  AI_CALLING
  VIDEO_PROCESSING
  VIDEO_STORAGE
  EMAIL_SEND
  SMS_SEND
  WHATSAPP_SEND
  STORAGE
  API_CALL
  CUSTOM
}

// Admin-configurable pricing per metric — the pricing table
model PricingRule {
  id              String   @id @default(cuid())
  feature         UsageFeature
  model           String?  @db.VarChar(128)  // null = applies to all models for this feature
  provider        String?  @db.VarChar(64)

  // Credits charged per unit
  creditsPerInputToken     Float @default(0)
  creditsPerOutputToken    Float @default(0)
  creditsPerVideoMinute    Float @default(0)
  creditsPerImage          Float @default(0)
  creditsPerSms            Float @default(0)
  creditsPerEmail          Float @default(0)
  creditsPerStorageGbDay   Float @default(0)
  creditsPerApiCall        Float @default(0)

  // Provider cost (what we pay) — for margin calculation
  providerCostPerInputToken    Float @default(0)  // USD
  providerCostPerOutputToken   Float @default(0)  // USD
  providerCostPerVideoMinute   Float @default(0)
  providerCostPerImage         Float @default(0)

  // Margin settings
  marginPct       Float    @default(30)          // default 30% margin
  marginFixed     Float    @default(0)           // flat USD add-on per request

  // USD ↔ credit exchange rate for this rule (fallback to global)
  creditsPerUsd   Float?

  isActive        Boolean  @default(true)
  note            String?  @db.VarChar(255)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([feature, model, provider])
  @@index([feature])
  @@index([isActive])
}

// Global billing configuration (singleton, managed by super-admin)
model BillingConfig {
  id              String   @id @default(cuid())
  key             String   @unique @db.VarChar(128)
  value           String   @db.Text
  description     String?  @db.VarChar(255)
  updatedAt       DateTime @updatedAt
}

// Purchasable credit bundles (100 credits = $10, etc.)
model CreditBundle {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(128)    // "Starter Pack", "Pro Pack"
  credits         Float                         // credits granted
  priceUsd        Float                         // list price in USD
  discountPct     Float    @default(0)          // e.g. 10 = 10% off
  bonusCredits    Float    @default(0)          // extra free credits
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  description     String?  @db.VarChar(255)
  stripePriceId   String?                       // Stripe one-time price ID
  paystackPlanCode String?

  transactions    CreditTransaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// M-Pesa STK push payment tracking
model MpesaPayment {
  id                  String   @id @default(cuid())
  organizationId      String
  phoneNumber         String   @db.VarChar(20)
  amountKes           Float
  merchantRequestId   String?  @unique
  checkoutRequestId   String?  @unique
  resultCode          Int?
  resultDesc          String?  @db.VarChar(255)
  mpesaReceiptNumber  String?  @unique
  transactionDate     DateTime?
  status              MpesaPaymentStatus @default(PENDING)
  creditBundleId      String?
  creditsGranted      Float?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([checkoutRequestId])
}

enum MpesaPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  TIMEOUT
}

// Crypto payment session (Coinbase Commerce / NOWPayments)
model CryptoPayment {
  id              String   @id @default(cuid())
  organizationId  String
  provider        String   @db.VarChar(64)   // "COINBASE" | "NOWPAYMENTS"
  chargeId        String?  @unique           // Coinbase charge ID
  paymentId       String?  @unique           // NOWPayments payment ID
  amountUsd       Float
  currency        String   @db.VarChar(20)   // "BTC", "ETH", "USDT", etc.
  cryptoAmount    Float?
  cryptoAddress   String?  @db.VarChar(255)
  status          CryptoPaymentStatus @default(PENDING)
  hostedUrl       String?  @db.Text
  expiresAt       DateTime?
  confirmedAt     DateTime?
  creditBundleId  String?
  creditsGranted  Float?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum CryptoPaymentStatus {
  PENDING
  WAITING
  CONFIRMING
  CONFIRMED
  FAILED
  EXPIRED
  CANCELLED
}

// ============================================================================
// END CREDIT-BASED BILLING SYSTEM
// ============================================================================

// Immutable log of every incoming webhook event
model IncomingWebhookLog {
  id             String  @id @default(cuid())
  connectionId   String?
  connection     IntegrationConnection? @relation(fields: [connectionId], references: [id])
  organizationId String?
  provider       String
  eventType      String
  payload        Json
  headers        Json?
  signatureValid Boolean @default(false)
  processed      Boolean @default(false)
  processingError String? @db.Text
  receivedAt     DateTime @default(now())

  @@index([provider])
  @@index([organizationId])
  @@index([eventType])
  @@index([processed])
  @@index([receivedAt])
}

// ============================================================================
// AI-POWERED VIDEO CREATION & EDITING ENGINE
// ============================================================================

model VideoProject {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation("OrgVideos", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         String
  creator           User     @relation("VideoProjectCreator", fields: [createdBy], references: [id])

  title             String   @db.VarChar(255)
  description       String?  @db.Text
  thumbnail        String?  // URL to thumbnail image

  // Project metadata
  duration          Float?   // Total duration in seconds (calculated)
  aspectRatio       AspectRatio @default(LANDSCAPE_16_9)
  resolution        String   @default("1080p") // 720p, 1080p, 4K
  fps               Int      @default(30)

  // Status tracking
  status            VideoProjectStatus @default(DRAFT)
  editingState      Json?   // Serialized editing timeline & clips
  renderProgress    Float    @default(0) // 0-100%

  // Rendering & output
  sourceVideos      VideoClip[] @relation("ProjectClips")
  renders           VideoRender[]
  exportSettings    VideoExportSettings?

  // Collaboration & versioning
  versions          VideoProjectVersion[]
  sharedWith        VideoProjectShare[]
  commentCount      Int      @default(0)

  // AI features
  autoEditingResults AutoEditingJob?
  aiScriptGenerated String?  @db.Text

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastEditedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([createdBy])
  @@index([status])
  @@index([createdAt])
}

model VideoClip {
  id                String   @id @default(cuid())
  projectId         String
  project           VideoProject @relation("ProjectClips", fields: [projectId], references: [id], onDelete: Cascade)

  // Source video
  sourceUrl         String   @db.Text // S3 or external URL
  fileName          String   @db.VarChar(255)
  fileSize          Float    // bytes
  duration          Float    // seconds
  width             Int
  height            Int

  // Clip properties
  startTime         Float    @default(0)     // Trim start (seconds)
  endTime           Float?                   // Trim end (seconds)
  displayOrder      Int      @default(0)    // Position in timeline
  speed             Float    @default(1.0)  // 0.5x, 1x, 2x, etc.
  volume            Float    @default(100)  // 0-100%
  opacity           Float    @default(100)  // 0-100%

  // Transformations
  rotation          Int      @default(0)    // 0, 90, 180, 270
  flipHorizontal    Boolean  @default(false)
  flipVertical      Boolean  @default(false)

  // Positioning & scaling
  x                 Float    @default(0)    // Position in timeline (seconds)
  scaleX            Float    @default(1.0)
  scaleY            Float    @default(1.0)

  // Effects & filters
  brightness        Float    @default(100)  // 0-200%
  contrast          Float    @default(100)  // 0-200%
  saturation        Float    @default(100)  // 0-200%
  hue               Float    @default(0)    // -180 to 180

  // Transitions
  transitionIn      TransitionType?
  transitionOut     TransitionType?
  transitionDuration Float   @default(0.5) // seconds

  // Audio
  hasAudio          Boolean  @default(true)
  audioTracks       AudioTrack[]

  // Background removal & effects
  backgroundRemoved Boolean  @default(false)
  backgroundRemovalResult Json? // Confidence scores, etc.

  // AI features
  autoCaption       VideoCaption?
  sceneDectected    SceneDetection?
  highlightScore    Float?  // AI highlight detection score (0-1)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([displayOrder])
}

model AudioTrack {
  id                String   @id @default(cuid())
  clipId            String
  clip              VideoClip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  sourceUrl         String   @db.Text
  fileName          String   @db.VarChar(255)
  duration          Float    // seconds

  trackType         AudioTrackType @default(ORIGINAL) // ORIGINAL, MUSIC, SFX, VOICEOVER
  volume            Float    @default(100)
  startTime         Float    @default(0)
  fadeIn            Float    @default(0)  // seconds
  fadeOut           Float    @default(0)  // seconds

  // Music metadata (if using stock music library)
  musicTitle        String?
  musicArtist       String?
  licensedFor       String?  // "social", "commercial", etc.

  createdAt         DateTime @default(now())

  @@index([clipId])
}

model VideoCaption {
  id                String   @id @default(cuid())
  clipId            String   @unique
  clip              VideoClip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  // Caption source
  sourceType        CaptionSourceType @default(AUTO)  // AUTO, UPLOAD, MANUAL
  transcriptUrl     String?  @db.Text // URL to SRT/VTT file
  transcript        String?  @db.Text // JSON array of caption objects

  // Styling
  font              String   @default("Arial")
  fontSize          Int      @default(24)
  color             String   @default("#FFFFFF")
  backgroundColor   String?
  position          CaptionPosition @default(BOTTOM)
  opacity           Float    @default(100)

  // Auto-styling settings
  autoStyle         Boolean  @default(false)
  stylePreset       String?  // "modern", "classic", "bold", etc.

  // Language & TTS
  language          String   @default("en")
  textToSpeech      Boolean  @default(false)
  ttVoice           String?  // Voice ID for TTS

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SceneDetection {
  id                String   @id @default(cuid())
  clipId            String   @unique
  clip              VideoClip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  scenes            Json     // Array of { startTime, endTime, confidence, label }
  sceneCount        Int

  createdAt         DateTime @default(now())
}

model VideoRender {
  id                String   @id @default(cuid())
  projectId         String
  project           VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Render settings
  format            VideoFormat @default(MP4)
  quality           VideoQuality @default(HIGH)
  bitrate           String   // "5M", "10M", etc.

  // Status tracking
  status            RenderStatus @default(QUEUED)
  progress          Float    @default(0) // 0-100%

  // Output
  outputUrl         String?  @db.Text // S3 URL when complete
  fileSize          Float?   // bytes
  duration          Float?   // seconds

  // Rendering metadata
  startedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?  @db.Text
  processingTime    Float?   // seconds

  // Usage tracking
  creditsCost       Float?   // For cost calculation

  createdAt         DateTime @default(now())

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model VideoExportSettings {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Export presets (for different platforms)
  instagramFormat   ExportPreset?  // 1080x1350 (Portrait), 1080x1080 (Square), 1920x1080 (Landscape)
  tiktokFormat      ExportPreset?  // 1080x1920 (Portrait)
  youtubeFormat     ExportPreset?  // 1920x1080 (16:9)
  linkedinFormat    ExportPreset?  // 1200x628 (16:9)

  // Default export settings
  defaultFormat     VideoFormat @default(MP4)
  defaultQuality    VideoQuality @default(HIGH)
  defaultAspectRatio AspectRatio @default(LANDSCAPE_16_9)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VideoProjectVersion {
  id                String   @id @default(cuid())
  projectId         String
  project           VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versionNumber     Int
  name              String?  @db.VarChar(255)
  editingState      Json    // Serialized state snapshot

  createdBy         String
  creator           User     @relation("VideoVersionCreator", fields: [createdBy], references: [id])

  createdAt         DateTime @default(now())

  @@unique([projectId, versionNumber])
  @@index([projectId])
}

model VideoProjectShare {
  id                String   @id @default(cuid())
  projectId         String
  project           VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId            String
  user              User     @relation("SharedVideoProjects", fields: [userId], references: [id], onDelete: Cascade)

  permission        SharePermission @default(VIEW)
  sharedAt          DateTime @default(now())
  expiresAt         DateTime?

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model AutoEditingJob {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // AI Analysis
  status            AutoEditingStatus @default(PENDING)
  analysisType      String   // "highlight_reel", "auto_cut", "scene_sync"

  // Results
  suggestedClips    Json?    // Array of suggested edits with timestamps
  suggestedEffects  Json?    // Array of suggested transitions/effects
  suggestedMusic    Json?    // Array of music suggestions

  // Application
  appliedEdits      Int      @default(0)
  confidence        Float?   // Average confidence score (0-1)

  // Generation method
  aiModel           String   // "gpt-4-vision", "claude-video", etc.
  scriptInput       String?  @db.Text // User-provided script for AI to follow

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

