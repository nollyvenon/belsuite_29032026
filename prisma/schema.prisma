// ============================================================================
// UPDATE ORGANIZATION MODEL WITH TENANT FIELDS
// ============================================================================

// Note: The Organization model has been enhanced with these fields already:
// - Tenant-related fields for multi-tenancy support
// - Relations: TenantDomains, TenantUsage, TenantRateLimits, TenantRateLimitUsage, TenantOnboarding, ApiRateLimitState
// - See Organization model above for full details

// ============================================================================
// VIDEO ENGINE - AI Video Creation & Editing (CapCut-style)
// ============================================================================

enum VideoStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum VideoJobType {
  RENDER          // Full render from timeline
  GENERATE_SCENE  // AI scene generation
  GENERATE_AUDIO  // TTS voiceover
  GENERATE_SUBS   // Auto-subtitle extraction
  TRANSCODE       // Format conversion
  THUMBNAIL       // Thumbnail generation
}

enum VideoJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum VideoMediaType {
  VIDEO_CLIP
  AUDIO_CLIP
  IMAGE
  SUBTITLE_TRACK
  VOICEOVER
  BACKGROUND_MUSIC
}

// A video project (the main unit of work)
model VideoProject {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation("OrgVideos", fields: [organizationId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User         @relation("UserVideos", fields: [createdById], references: [id])

  title           String       @db.VarChar(255)
  description     String?      @db.Text
  script          String?      @db.Text   // Raw script used for generation
  status          VideoStatus  @default(DRAFT)

  // Output file details (set when render completes)
  outputUrl       String?      @db.Text
  thumbnailUrl    String?      @db.Text
  durationMs      Int?                    // milliseconds
  fileSizeBytes   BigInt?

  // Timeline state — stored as JSON blob
  timelineJson    String?      @db.Text   // serialised TimelineState

  // Resolution / format
  width           Int          @default(1920)
  height          Int          @default(1080)
  fps             Int          @default(30)
  format          String       @default("mp4") @db.VarChar(16)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  mediaAssets     MediaAsset[]
  processingJobs  VideoJob[]
  scenes          VideoScene[]
  subtitleTracks  SubtitleTrack[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

// Individual media asset (clip, image, audio) in the library
model MediaAsset {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation("OrgMedia", fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedById    String
  uploadedBy      User         @relation("UserMedia", fields: [uploadedById], references: [id])
  videoProjectId  String?
  videoProject    VideoProject? @relation(fields: [videoProjectId], references: [id], onDelete: SetNull)

  name            String       @db.VarChar(255)
  mediaType       VideoMediaType
  mimeType        String       @db.VarChar(128)
  storageKey      String       @db.Text   // S3/storage path
  publicUrl       String?      @db.Text
  fileSizeBytes   BigInt?
  durationMs      Int?                    // audio/video only
  width           Int?                    // video/image
  height          Int?

  // AI generation metadata
  aiGenerated     Boolean      @default(false)
  aiPrompt        String?      @db.Text

  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([videoProjectId])
  @@index([mediaType])
}

// A scene in the video (maps to a section of the timeline)
model VideoScene {
  id              String       @id @default(cuid())
  videoProjectId  String
  videoProject    VideoProject @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  order           Int                     // Scene order (0-based)
  scriptSegment   String?      @db.Text   // Script text for this scene
  durationMs      Int          @default(5000)

  // Visual
  backgroundUrl   String?      @db.Text
  aiImagePrompt   String?      @db.Text   // Prompt used to generate background

  // Voiceover
  voiceoverUrl    String?      @db.Text
  voiceoverText   String?      @db.Text
  ttsVoiceId      String?      @db.VarChar(128)  // ElevenLabs / OpenAI voice id

  // Overlays / text stored as JSON
  overlaysJson    String?      @db.Text

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([videoProjectId])
  @@index([order])
}

// Subtitle track for a project
model SubtitleTrack {
  id              String       @id @default(cuid())
  videoProjectId  String
  videoProject    VideoProject @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  language        String       @default("en") @db.VarChar(16)
  srtContent      String?      @db.Text   // Full SRT file content
  vttContent      String?      @db.Text   // WebVTT content
  storageKey      String?      @db.Text   // path to stored file

  autoGenerated   Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ============================================================================
// MARKETING ENGINE — AI Ad Generation, Campaigns, A/B Tests, Funnels
// ============================================================================

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignObjective {
  AWARENESS       // Reach / impressions
  TRAFFIC         // Clicks to website
  ENGAGEMENT      // Likes, comments, shares
  LEADS           // Lead generation form
  CONVERSIONS     // Purchase / sign-up
  APP_INSTALLS    // Mobile app installs
  VIDEO_VIEWS     // Video play events
}

enum AdPlatform {
  FACEBOOK
  INSTAGRAM
  GOOGLE_SEARCH
  GOOGLE_DISPLAY
  GOOGLE_YOUTUBE
  TIKTOK_ADS
  LINKEDIN_ADS
  TWITTER_ADS
}

enum AdFormat {
  SINGLE_IMAGE
  CAROUSEL
  VIDEO
  COLLECTION
  STORY
  RESPONSIVE_SEARCH    // Google RSA
  RESPONSIVE_DISPLAY   // Google GDN
}

enum AdStatus {
  DRAFT
  IN_REVIEW
  ACTIVE
  PAUSED
  REJECTED
  COMPLETED
}

enum ABTestStatus {
  DRAFT
  RUNNING
  CONCLUDED
  ARCHIVED
}

enum FunnelStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConversionEventType {
  PAGE_VIEW
  CLICK
  FORM_SUBMIT
  PURCHASE
  SIGNUP
  DOWNLOAD
  PHONE_CALL
  VIDEO_PLAY
  CUSTOM
}

// ─── Ad Platform Accounts (Facebook Ads Manager, Google Ads) ─────────────────

model AdPlatformAccount {
  id               String      @id @default(cuid())
  organizationId   String
  organization     Organization @relation("OrgAdAccounts", fields: [organizationId], references: [id], onDelete: Cascade)

  platform         AdPlatform
  accountId        String      @db.VarChar(128)  // platform's account ID
  accountName      String      @db.VarChar(255)
  currencyCode     String      @default("USD") @db.VarChar(8)
  timezone         String      @default("UTC")

  // Encrypted OAuth tokens
  accessToken      String      @db.Text
  refreshToken     String?     @db.Text
  tokenExpiresAt   DateTime?

  isActive         Boolean     @default(true)
  syncedAt         DateTime?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  campaigns        MarketingCampaign[]

  @@unique([organizationId, platform, accountId])
  @@index([organizationId])
  @@index([platform])
}

// ─── Marketing Campaign ───────────────────────────────────────────────────────

model MarketingCampaign {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation("OrgCampaigns", fields: [organizationId], references: [id], onDelete: Cascade)
  adAccountId      String?
  adAccount        AdPlatformAccount? @relation(fields: [adAccountId], references: [id], onDelete: SetNull)

  name             String            @db.VarChar(255)
  description      String?           @db.Text
  objective        CampaignObjective
  status           CampaignStatus    @default(DRAFT)

  // Budget
  dailyBudget      Float?            // USD
  totalBudget      Float?            // USD
  spentBudget      Float             @default(0)

  // Schedule
  startDate        DateTime?
  endDate          DateTime?

  // Target audience (JSON blob: age, gender, interests, locations, lookalike)
  audienceJson     String?           @db.Text

  // Platform campaign ID (set after sync)
  platformCampaignId String?         @db.VarChar(255)

  // AI metadata
  aiGenerated      Boolean           @default(false)
  aiNotes          String?           @db.Text

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  ads              Ad[]
  abTests          ABTest[]
  performanceSnapshots CampaignPerformance[]

  @@index([organizationId])
  @@index([status])
  @@index([startDate])
}

// ─── Ad ──────────────────────────────────────────────────────────────────────

model Ad {
  id               String            @id @default(cuid())
  campaignId       String
  campaign         MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name             String            @db.VarChar(255)
  format           AdFormat
  status           AdStatus          @default(DRAFT)

  // Copy
  headline         String?           @db.VarChar(512)
  body             String?           @db.Text
  callToAction     String?           @db.VarChar(64)  // "Shop Now", "Learn More"
  destinationUrl   String?           @db.Text

  // Creative assets (JSON array of URLs / storage keys)
  creativeAssets   String?           @db.Text  // JSON: [{type, url, altText}]

  // AI generation
  aiGenerated      Boolean           @default(false)
  aiPrompt         String?           @db.Text
  aiScore          Float?            // AI-predicted quality score 0-100

  // Platform ad ID (set after sync)
  platformAdId     String?           @db.VarChar(255)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  variants         AdVariant[]
  impressions      AdPerformance[]
  conversions      ConversionEvent[]

  @@index([campaignId])
  @@index([status])
}

// ─── Ad Variant (A/B test copy variant) ──────────────────────────────────────

model AdVariant {
  id               String    @id @default(cuid())
  adId             String
  ad               Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)
  abTestId         String?
  abTest           ABTest?   @relation(fields: [abTestId], references: [id], onDelete: SetNull)

  label            String    @db.VarChar(64)  // "A", "B", "C"
  headline         String?   @db.VarChar(512)
  body             String?   @db.Text
  callToAction     String?   @db.VarChar(64)
  creativeAssets   String?   @db.Text  // JSON array

  // Metrics (live aggregated)
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  conversions      Int       @default(0)
  spend            Float     @default(0)

  isWinner         Boolean   @default(false)
  isControl        Boolean   @default(false)  // The baseline variant

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([adId])
  @@index([abTestId])
}

// ─── A/B Test ─────────────────────────────────────────────────────────────────

model ABTest {
  id               String           @id @default(cuid())
  campaignId       String
  campaign         MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name             String           @db.VarChar(255)
  hypothesis       String?          @db.Text
  metric           String           @db.VarChar(64)  // "ctr", "cpc", "cvr", "roas"
  status           ABTestStatus     @default(DRAFT)

  // Statistical parameters
  confidenceLevel  Float            @default(0.95)   // 95%
  minimumSampleSize Int             @default(1000)
  trafficSplit     String           @db.Text          // JSON: {"A": 50, "B": 50}

  // Results
  winnerVariantId  String?
  pValue           Float?
  statisticalPower Float?
  conclusionNotes  String?          @db.Text

  startedAt        DateTime?
  concludedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  variants         AdVariant[]

  @@index([campaignId])
  @@index([status])
}

// ─── Campaign Performance Snapshot ───────────────────────────────────────────

model CampaignPerformance {
  id               String            @id @default(cuid())
  campaignId       String
  campaign         MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date             DateTime          @db.Date     // Daily snapshot date
  impressions      Int               @default(0)
  clicks           Int               @default(0)
  conversions      Int               @default(0)
  spend            Float             @default(0)
  revenue          Float             @default(0)

  // Derived (computed on write)
  ctr              Float             @default(0)  // clicks/impressions
  cpc              Float             @default(0)  // spend/clicks
  cpa              Float             @default(0)  // spend/conversions
  roas             Float             @default(0)  // revenue/spend

  // Breakdown by platform (JSON: {FACEBOOK: {...}, GOOGLE: {...}})
  platformBreakdown String?          @db.Text

  createdAt        DateTime          @default(now())

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

// ─── Ad Performance (per-ad per-day) ─────────────────────────────────────────

model AdPerformance {
  id               String    @id @default(cuid())
  adId             String
  ad               Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)
  date             DateTime  @db.Date

  impressions      Int       @default(0)
  clicks           Int       @default(0)
  conversions      Int       @default(0)
  spend            Float     @default(0)
  revenue          Float     @default(0)
  frequency        Float     @default(0)  // avg times shown per user

  createdAt        DateTime  @default(now())

  @@unique([adId, date])
  @@index([adId])
  @@index([date])
}

// ─── Conversion Event ─────────────────────────────────────────────────────────

model ConversionEvent {
  id               String              @id @default(cuid())
  organizationId   String
  organization     Organization        @relation("OrgConversions", fields: [organizationId], references: [id], onDelete: Cascade)
  adId             String?
  ad               Ad?                 @relation(fields: [adId], references: [id], onDelete: SetNull)

  eventType        ConversionEventType
  eventName        String?             @db.VarChar(128)  // Custom event name
  funnelPageId     String?

  // Attribution
  utmSource        String?             @db.VarChar(128)
  utmMedium        String?             @db.VarChar(128)
  utmCampaign      String?             @db.VarChar(255)
  utmContent       String?             @db.VarChar(255)
  utmTerm          String?             @db.VarChar(255)
  clickId          String?             @db.VarChar(255)  // fbclid / gclid

  // Session / visitor
  sessionId        String?             @db.VarChar(255)
  visitorId        String?             @db.VarChar(255)  // anonymous fingerprint
  ipAddress        String?             @db.VarChar(64)
  userAgent        String?             @db.Text
  referrer         String?             @db.Text
  pageUrl          String?             @db.Text

  // Value
  value            Float?              // monetary conversion value
  currency         String?             @db.VarChar(8)

  // Raw payload for custom events
  metadataJson     String?             @db.Text

  occurredAt       DateTime            @default(now())

  @@index([organizationId])
  @@index([adId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([utmCampaign])
}

// ─── Funnel ───────────────────────────────────────────────────────────────────

model Funnel {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation("OrgFunnels", fields: [organizationId], references: [id], onDelete: Cascade)

  name             String        @db.VarChar(255)
  description      String?       @db.Text
  status           FunnelStatus  @default(DRAFT)

  // Custom domain / slug
  slug             String        @db.VarChar(128)
  domain           String?       @db.VarChar(255)

  // Global styles (JSON: colors, fonts, borders)
  themeJson        String?       @db.Text

  aiGenerated      Boolean       @default(false)

  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  pages            FunnelPage[]
  metrics          FunnelMetrics[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
}

// ─── Funnel Page ──────────────────────────────────────────────────────────────

model FunnelPage {
  id               String    @id @default(cuid())
  funnelId         String
  funnel           Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  order            Int                   // Step number (0 = opt-in, 1 = upsell, etc.)
  pageType         String    @db.VarChar(64)  // "optin", "salespage", "upsell", "thankyou"
  title            String    @db.VarChar(255)
  slug             String    @db.VarChar(128)

  // Page content as block-based JSON (similar to Notion blocks)
  blocksJson       String?   @db.Text

  // Conversion element
  ctaText          String?   @db.VarChar(128)
  ctaUrl           String?   @db.Text
  nextPageId       String?   @db.VarChar(255) // nextStep within funnel

  // Tracking
  views            Int       @default(0)
  conversions      Int       @default(0)

  // SEO
  metaTitle        String?   @db.VarChar(255)
  metaDescription  String?   @db.Text

  aiGenerated      Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([funnelId, slug])
  @@index([funnelId])
  @@index([order])
}

// ─── Funnel Metrics (event stream) ───────────────────────────────────────────

model FunnelMetrics {
  id               String    @id @default(cuid())
  funnelId         String
  funnel           Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  date             DateTime  @db.Date
  pageId           String?   @db.VarChar(255)

  views            Int       @default(0)
  uniqueVisitors   Int       @default(0)
  conversions      Int       @default(0)
  exits            Int       @default(0)
  bounces          Int       @default(0)
  avgTimeOnPage    Float     @default(0)  // seconds

  createdAt        DateTime  @default(now())

  @@unique([funnelId, date, pageId])
  @@index([funnelId])
  @@index([date])
}

// Background processing job for video operations
model VideoJob {
  id              String          @id @default(cuid())
  videoProjectId  String
  videoProject    VideoProject    @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  jobType         VideoJobType
  status          VideoJobStatus  @default(QUEUED)
  bullJobId       String?         @db.VarChar(255)  // BullMQ job id
  progress        Int             @default(0)       // 0-100

  // Input/output stored as JSON
  inputJson       String?         @db.Text
  outputJson      String?         @db.Text
  errorMessage    String?         @db.Text

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@index([videoProjectId])
  @@index([status])
  @@index([jobType])
  @@index([createdAt])
}

// ============================================================================
// SOCIAL MEDIA SCHEDULER
// ============================================================================

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  TWITTER
  LINKEDIN
  PINTEREST
  WHATSAPP
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum PublishStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum BulkBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

// Connected social media account (one per platform per user per org)
model SocialAccount {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         SocialPlatform
  platformUserId   String
  platformUsername String?
  displayName      String?
  avatar           String?
  accessToken      String         @db.Text // AES-256-GCM encrypted
  refreshToken     String?        @db.Text // AES-256-GCM encrypted
  tokenExpiresAt   DateTime?
  scope            String?
  pageId           String?        // Facebook/Instagram page ID
  pageName         String?
  isActive         Boolean        @default(true)
  metadata         Json?          // Extra platform-specific data (e.g., WhatsApp recipients list)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  posts            ScheduledPostAccount[]
  publishResults   PostPublishResult[]

  @@unique([organizationId, platform, platformUserId])
  @@index([organizationId])
  @@index([userId])
  @@index([platform])
}

// A scheduled (or published) social post
model ScheduledPost {
  id                  String         @id @default(cuid())
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById         String
  createdBy           User           @relation(fields: [createdById], references: [id])
  content             String         @db.Text
  mediaUrls           String[]       @default([]) // CDN URLs
  mediaKeys           String[]       @default([]) // S3 keys
  link                String?
  hashtags            String[]       @default([])
  status              PostStatus     @default(DRAFT)
  scheduledAt         DateTime?
  publishedAt         DateTime?

  // AI creation metadata
  aiGenerated         Boolean        @default(false)
  aiPrompt            String?        @db.Text
  optimalTimeUsed     Boolean        @default(false)

  // Auto-repost settings
  autoRepostEnabled   Boolean        @default(false)
  repostIntervalDays  Int?
  maxReposts          Int?           @default(0)
  repostCount         Int            @default(0)
  nextRepostAt        DateTime?
  parentPostId        String?
  parentPost          ScheduledPost? @relation("PostReposts", fields: [parentPostId], references: [id])
  reposts             ScheduledPost[] @relation("PostReposts")

  // Bulk batch
  bulkBatchId         String?
  bulkBatch           BulkBatch?     @relation(fields: [bulkBatchId], references: [id])

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  accounts            ScheduledPostAccount[]
  publishResults      PostPublishResult[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextRepostAt])
  @@index([bulkBatchId])
}

// Many-to-many: ScheduledPost <-> SocialAccount
model ScheduledPostAccount {
  postId    String
  post      ScheduledPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId String
  account   SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([postId, accountId])
}

// Per-account publish result for a post
model PostPublishResult {
  id              String         @id @default(cuid())
  postId          String
  post            ScheduledPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId       String
  account         SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform        SocialPlatform
  status          PublishStatus  @default(PENDING)
  platformPostId  String?        // ID returned by the platform
  platformUrl     String?        // Public URL of the post
  errorMessage    String?        @db.Text
  attemptCount    Int            @default(0)
  nextRetryAt     DateTime?
  publishedAt     DateTime?
  dismissedAt     DateTime?      // set when user acknowledges a failure
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([postId])
  @@index([accountId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([dismissedAt])
}

// Bulk posting batch
model BulkBatch {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String          @db.VarChar(255)
  totalPosts      Int             @default(0)
  scheduledPosts  Int             @default(0)
  publishedPosts  Int             @default(0)
  failedPosts     Int             @default(0)
  status          BulkBatchStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  posts           ScheduledPost[]

  @@index([organizationId])
  @@index([status])
}

// Learned optimal posting times per org per platform
model OptimalPostingTime {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform        SocialPlatform
  dayOfWeek       Int            // 0=Sun, 6=Sat
  hour            Int            // 0-23 UTC
  score           Float          @default(0.5) // 0-1 engagement score
  updatedAt       DateTime       @updatedAt

  @@unique([organizationId, platform, dayOfWeek, hour])
  @@index([organizationId, platform])
}

// ============================================================================
// UGC CONTENT GENERATOR - AI Avatar Videos, Voice Cloning, Script-to-Video
// ============================================================================

enum UGCProjectStatus {
  DRAFT
  SCRIPTING
  RENDERING
  READY
  PUBLISHED
  FAILED
}

enum AvatarStyle {
  INFLUENCER
  PROFESSIONAL
  CASUAL
  PRESENTER
  NARRATOR
}

enum AvatarProvider {
  HEYGEN
  DID
  TAVUS
  SYNTHESIA
  MOCK
}

enum VoiceGender {
  MALE
  FEMALE
  NEUTRAL
}

enum RenderStatus {
  QUEUED
  PROCESSING
  COMPLETE
  FAILED
}

// --- UGC Avatar ---------------------------------------------------------------

model UGCAvatar {
  id              String         @id @default(cuid())
  organizationId  String?
  organization    Organization?  @relation("OrgUGCAvatars", fields: [organizationId], references: [id], onDelete: Cascade)

  name            String         @db.VarChar(255)
  description     String?        @db.Text
  style           AvatarStyle    @default(INFLUENCER)
  provider        AvatarProvider @default(HEYGEN)
  externalId      String?        @db.VarChar(255)   // HeyGen/D-ID avatar ID
  thumbnailUrl    String?        @db.Text
  previewVideoUrl String?        @db.Text

  gender          VoiceGender    @default(FEMALE)
  ethnicityHint   String?        @db.VarChar(128)
  ageRange        String?        @db.VarChar(64)    // e.g. "25-35"

  isActive        Boolean        @default(true)
  isSystem        Boolean        @default(false)    // Built-in system avatar

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  projects        UGCProject[]

  @@index([organizationId])
  @@index([style])
  @@index([provider])
  @@index([isSystem])
}

// --- Voice Clone --------------------------------------------------------------

model VoiceClone {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation("OrgVoiceClones", fields: [organizationId], references: [id], onDelete: Cascade)

  name            String       @db.VarChar(255)
  description     String?      @db.Text

  // ElevenLabs / provider ref
  provider        String       @db.VarChar(64) @default("elevenlabs")
  externalVoiceId String?      @db.VarChar(255)

  // Sample audio used for cloning
  sampleAudioUrl  String?      @db.Text

  gender          VoiceGender  @default(FEMALE)
  language        String       @db.VarChar(16) @default("en")
  accent          String?      @db.VarChar(64)

  // Playback settings
  stability       Float        @default(0.5)
  similarityBoost Float        @default(0.75)
  styleExaggeration Float      @default(0.0)

  isActive        Boolean      @default(true)
  isDefault       Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  projects        UGCProject[]

  @@index([organizationId])
  @@index([provider])
  @@index([isDefault])
}

// --- UGC Project -------------------------------------------------------------

model UGCProject {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation("OrgUGCProjects", fields: [organizationId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User             @relation("UserUGCProjects", fields: [createdById], references: [id])

  title           String           @db.VarChar(255)
  description     String?          @db.Text

  // Brand voice context (JSON: tone, personality, keywords, cta, etc.)
  brandContext    String?          @db.Text

  // Avatar
  avatarId        String?
  avatar          UGCAvatar?       @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  // Voice clone
  voiceCloneId    String?
  voiceClone      VoiceClone?      @relation(fields: [voiceCloneId], references: [id], onDelete: SetNull)

  status          UGCProjectStatus @default(DRAFT)

  // Script
  script          UGCScript?

  // Renders
  renders         UGCRender[]

  // Output settings
  aspectRatio     String           @db.VarChar(16) @default("9:16")
  durationSeconds Int?
  platform        String?          @db.VarChar(64)   // tiktok, instagram, youtube, etc.

  // Final output
  outputUrl       String?          @db.Text
  thumbnailUrl    String?          @db.Text

  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

// --- UGC Script ---------------------------------------------------------------

model UGCScript {
  id              String     @id @default(cuid())
  projectId       String     @unique
  project         UGCProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  content         String     @db.Text

  // AI generation info
  aiGenerated     Boolean    @default(false)
  prompt          String?    @db.Text
  model           String?    @db.VarChar(128)

  // Scene breakdown (JSON array of { text, durationHint, visualNote })
  scenesJson      String?    @db.Text

  wordCount       Int?
  estimatedSecs   Int?
  version         Int        @default(1)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([projectId])
}

// --- UGC Render ---------------------------------------------------------------

model UGCRender {
  id              String      @id @default(cuid())
  projectId       String
  project         UGCProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status          RenderStatus @default(QUEUED)

  // Provider job tracking
  provider        String      @db.VarChar(64) @default("heygen")
  externalJobId   String?     @db.VarChar(255)

  // Progress
  progress        Int         @default(0)  // 0-100

  // Output
  videoUrl        String?     @db.Text
  thumbnailUrl    String?     @db.Text
  durationSeconds Float?
  fileSizeBytes   BigInt?

  // Render config snapshot
  settingsJson    String?     @db.Text

  errorMessage    String?     @db.Text

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// MODULE 11: TEAMS & COLLABORATION
// ============================================================================

enum TeamRole {
  OWNER        // Full control, billing, team management
  ADMIN        // Manage team, users, permissions (no billing)
  EDITOR       // Create, edit, publish content
  CONTRIBUTOR  // Create content, cannot publish
  VIEWER       // Read-only access
  APPROVER     // Approve/reject content
}

enum ApprovalStatus {
  PENDING       // Awaiting approval
  APPROVED      // Approved by required approvers
  REJECTED      // Rejected with reason
  REVOKED       // Approval revoked by approver
  EXPIRED       // Approval expired
  CANCELLED     // Workflow cancelled before completion
}

enum TeamInvitationStatus {
  PENDING       // Invitation sent, awaiting acceptance
  ACCEPTED      // User accepted and joined team
  DECLINED      // User declined invitation
  REVOKED       // Admin revoked invitation
  EXPIRED       // Invitation expired
}

// ─── Teams ───────────────────────────────────────────────────────────────

model Team {
  id                String              @id @default(cuid())
  organizationId    String
  organization      Organization        @relation("OrgTeams", fields: [organizationId], references: [id], onDelete: Cascade)
  
  name              String              @db.VarChar(255)
  slug              String              @db.VarChar(128)
  description       String?             @db.Text
  
  // Access control
  isPublic          Boolean             @default(false)
  requiresApproval  Boolean             @default(true)   // Require approval workflows for content
  
  // Members & quota
  memberCount       Int                 @default(1)
  maxMembers        Int?                // Null = unlimited
  
  // Metadata
  metadata          String?             @db.Text         // JSON additional metadata
  
  // Owner / creator
  createdById       String
  createdBy         User                @relation("TeamCreator", fields: [createdById], references: [id])
  
  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  archivedAt        DateTime?           // Soft delete
  
  // Relations
  members           TeamMember[]
  invitations       TeamInvitation[]
  workflows         TeamWorkflow[]
  auditLogs         TeamAuditLog[]
  
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdById])
  @@index([createdAt])
  @@index([archivedAt])
}

// ─── Team Members ────────────────────────────────────────────────────────

model TeamMember {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User                @relation("TeamMember", fields: [userId], references: [id], onDelete: Cascade)
  
  role              TeamRole            @default(CONTRIBUTOR)
  
  // Status
  isActive          Boolean             @default(true)
  joinedAt          DateTime            @default(now())
  invitedAt         DateTime?           // When invited
  invitedBy         String?             // User ID who invited
  
  // Permissions cache (denormalized for performance)
  permissions       String[]            @default([])     // JSON array of permission strings
  
  // Last activity
  lastActivityAt    DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
}

// ─── Team Invitations ────────────────────────────────────────────────────

model TeamInvitation {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  // Invitee details
  invitedEmail      String              @db.VarChar(255)
  role              TeamRole            @default(CONTRIBUTOR)
  
  // Invitation metadata
  invitedBy         String
  invitedByUser     User                @relation("TeamInvited", fields: [invitedBy], references: [id])
  
  // Token & expiry
  token             String              @unique
  expiresAt         DateTime
  
  // Status & response
  status            TeamInvitationStatus @default(PENDING)
  acceptedAt        DateTime?
  acceptedByUserId  String?
  declinedAt        DateTime?
  revokedAt         DateTime?
  
  // Metadata
  message           String?             @db.Text
  
  createdAt         DateTime            @default(now())
  
  @@unique([teamId, invitedEmail])
  @@index([teamId])
  @@index([invitedEmail])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// ─── Team Workflows (Approval Workflows) ──────────────────────────────────

model TeamWorkflow {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  name              String              @db.VarChar(255)
  description       String?             @db.Text
  
  // Workflow configuration
  requiresApprovals Boolean             @default(true)
  requiredApprovals Int                 @default(1)      // Minimum approvals needed
  allowRejectReason Boolean             @default(true)
  
  // Applicable content types (JSON array: video, post, article, etc.)
  applicableContentTypes String[]       @default([])
  
  // Status
  isActive          Boolean             @default(true)
  
  // Trigger & notification config
  triggerConfig     String?             @db.Text         // JSON: triggers for auto-start
  notificationConfig String?            @db.Text         // JSON: notification settings
  
  // Statistics
  totalSubmissions  Int                 @default(0)
  approvedCount     Int                 @default(0)
  rejectedCount     Int                 @default(0)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  approvals         WorkflowApproval[]
  
  @@index([teamId])
  @@index([isActive])
}

// ─── Workflow Approvals (Approval Instances) ──────────────────────────────

model WorkflowApproval {
  id                String              @id @default(cuid())
  workflowId        String
  workflow          TeamWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  // Content being approved
  contentId         String              @db.VarChar(255)  // Content ID (video, post, article)
  contentType       String              @db.VarChar(128)  // Type of content
  
  // Submitter
  submittedById      String
  submittedBy       User                @relation("ApprovalSubmitter", fields: [submittedById], references: [id])
  
  // Status & reason
  status            ApprovalStatus      @default(PENDING)
  comments          String?             @db.Text         // Internal comments
  rejectionReason   String?             @db.Text         // If rejected
  
  // Approval chain
  requiredApprovals Int                 @default(1)
  receivedApprovals Int                 @default(0)
  
  // Versioning
  version           Int                 @default(1)      // Content version being approved
  contentSnapshot   String?             @db.Text         // JSON snapshot of content
  
  // Timestamps
  submittedAt       DateTime            @default(now())
  dueAt             DateTime?           // Optional deadline
  expiresAt         DateTime?           // Approval expires
  approvedAt        DateTime?
  rejectedAt        DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  approvals         Approval[]
  
  @@index([workflowId])
  @@index([contentId])
  @@index([submittedById])
  @@index([status])
  @@index([submittedAt])
  @@index([expiresAt])
}

// ─── Individual Approvals (One approval per approver per request) ────────

model Approval {
  id                String              @id @default(cuid())
  approvalRequestId String
  approvalRequest   WorkflowApproval    @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  
  // Approver
  approverId        String
  approver          User                @relation("Approver", fields: [approverId], references: [id])
  
  // Decision
  decision          String              @db.VarChar(32)   // APPROVED, REJECTED, or null for pending
  decisionReason    String?             @db.Text
  
  // Timestamps
  requestedAt       DateTime            @default(now())
  respondedAt       DateTime?
  expiresAt         DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([approvalRequestId, approverId])
  @@index([approvalRequestId])
  @@index([approverId])
  @@index([decision])
  @@index([expiresAt])
}

// ─── Team Audit Log (Immutable event log) ────────────────────────────────

model TeamAuditLog {
  id                String              @id @default(cuid())
  teamId            String
  team              Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  // Actor
  userId            String
  user              User                @relation("TeamAuditActor", fields: [userId], references: [id])
  
  // Event details
  action            String              @db.VarChar(128)  // e.g., "member.added", "content.approved"
  resourceType      String              @db.VarChar(128)  // e.g., "team", "member", "approval"
  resourceId        String?
  
  // Changes/details
  changes           String?             @db.Text         // JSON: before/after values
  details           String?             @db.Text         // JSON: additional context
  
  // Request context
  ipAddress         String?
  userAgent         String?
  
  // Immutable timestamp
  timestamp         DateTime            @default(now())
  
  @@index([teamId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([resourceType])
}

