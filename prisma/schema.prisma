// ============================================================================
// CONTENT ACTIVITY LOG
// ============================================================================

model ContentActivityLog {
  id            String   @id @default(cuid())
  contentId     String
  content       Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  organizationId String
  userId        String
    user          User     @relation("UserContentActivityLogs", fields: [userId], references: [id], onDelete: Cascade)
  action        ContentActionType
  message       String?  @db.Text // Optional: custom message or comment
  meta          String?  @db.Text // Optional: JSON metadata
  createdAt     DateTime @default(now())

  @@index([contentId])
  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum ContentActionType {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  RESTORE
  COMMENT
  SCHEDULE
  AUTOSAVE
  OTHER
}
// ============================================================================
// CONTENT VERSIONING
// ============================================================================

model ContentVersion {
  id            String   @id @default(cuid())
  contentId     String
  title         String   @db.VarChar(255)
  description   String?  @db.Text
  body          String?  @db.Text
  createdBy     String
    creator       User     @relation("UserContentVersions", fields: [createdBy], references: [id])
  createdAt     DateTime @default(now())

  @@index([contentId])
  @@index([createdBy])
  @@index([createdAt])
}
// Belsuite - Multi-Tenant SaaS Platform
// Comprehensive database schema for enterprise features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
    contentVersions       ContentVersion[] @relation("UserContentVersions")
  id                    String    @id @default(cuid())
  email                 String    @unique @db.VarChar(255)
  emailVerified         DateTime?
  passwordHash          String
  firstName             String?
  lastName              String?
  avatar                String?   // URL to profile picture
  phoneNumber           String?
  timezone              String    @default("UTC")
  preferredLanguage     String    @default("en")
  status                UserStatus @default(ACTIVE)
  lastLogin             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime? // Soft delete

  // Relations
  organizationMembers   OrganizationMember[]
  apiKeys               APIKey[]
  sessions              Session[]
  auditLogs             AuditLog[] @relation("UserAudit")
  invitations           Invitation[]
  notificationSettings  NotificationSettings?
  notifications         Notification[]
  contentCreated        Content[] @relation("ContentCreator")
  savedContent          SavedContent[]
  contentActivityLogs   ContentActivityLog[] @relation("UserContentActivityLogs")

  // Video editing
  videoProjects         VideoProject[] @relation("VideoProjectCreator")
  videoVersions         VideoProjectVersion[] @relation("VideoVersionCreator")
  sharedVideoProjects   VideoProjectShare[] @relation("SharedVideoProjects")

  // Growth engine
  deals                 Deal[] @relation("UserDeals")
  activities            Activity[] @relation("UserActivities")

  // AI features
  aiUsages              AIUsage[]
  promptTemplates       PromptTemplate[]

  // Video engine
  videoProjects         VideoProject[]  @relation("UserVideos")
  mediaAssets           MediaAsset[]    @relation("UserMedia")

  // Social media scheduler
  socialAccounts        SocialAccount[]
  scheduledPosts        ScheduledPost[]

  // UGC Content Generator
  ugcProjects           UGCProject[]   @relation("UserUGCProjects")

  // Module 11: Teams & Collaboration
  teamCreator           Team[]         @relation("TeamCreator")
  teamMembers           TeamMember[]   @relation("TeamMember")
  teamInvited           TeamInvitation[] @relation("TeamInvited")
  approvalSubmitter     WorkflowApproval[] @relation("ApprovalSubmitter")
  approvals             Approval[]     @relation("Approver")
  teamAuditLogs         TeamAuditLog[] @relation("TeamAuditActor")

  // Authentication relations
  oauthAccounts         OAuthAccount[]
  twoFactor             TwoFactorSecret?
  deviceSessions        DeviceSession[]
  passwordHistory       PasswordHistory[]
  emailVerifications    EmailVerificationToken[]
  passwordResets        PasswordResetToken[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  PENDING_VERIFICATION
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   String?   // Which org context this session is for
  refreshTokenHash String    @unique @db.VarChar(128) // SHA-256 hash of refresh token
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  ipAddress        String?
  userAgent        String?   @db.Text
  isRevoked        Boolean   @default(false)
  revokedAt        DateTime?
  revokedReason    String?   @db.VarChar(64)  // logout, password_change, admin, suspicious

  // Device tracking
  deviceSessions  DeviceSession[]

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

// OAuth Accounts (Google, Apple, Facebook)
model OAuthAccount {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          OAuthProvider
  providerUserId    String    @unique  // Google ID, Apple ID, etc.
  email             String?
  displayName       String?
  avatar            String?   // Profile picture from OAuth provider
  accessToken       String?   @db.Text // Encrypted
  refreshToken      String?   @db.Text // Encrypted
  expiresAt         DateTime?
  scope             String?   // Space-separated scopes
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([provider])
  @@index([userId])
}

enum OAuthProvider {
  GOOGLE
  APPLE
  FACEBOOK
}

// Two-Factor Authentication - TOTP (Authenticator Apps)
model TwoFactorSecret {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret            String    @db.Text // Encrypted base32 secret
  backupCodes       TwoFactorBackupCode[]
  isEnabled         Boolean   @default(false)
  enabledAt         DateTime?
  method            TwoFactorMethod // TOTP or EMAIL
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

enum TwoFactorMethod {
  TOTP              // Time-based One-Time Password (Authenticator apps)
  EMAIL             // Email-based 2FA
}

// Two-Factor Backup Codes
model TwoFactorBackupCode {
  id                String    @id @default(cuid())
  twoFactorId       String
  twoFactor         TwoFactorSecret @relation(fields: [twoFactorId], references: [id], onDelete: Cascade)
  code              String    @db.VarChar(16) // Hashed
  used              Boolean   @default(false)
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([twoFactorId])
}

// Device/Session Tracking for Security
model DeviceSession {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId         String
  session           Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Device Information
  deviceName        String?   // User-friendly name (iPhone 12, MacBook Pro)
  deviceType        DeviceType // MOBILE, DESKTOP, TABLET
  osName            String?   // iOS, Android, Windows, macOS, Linux
  osVersion         String?
  browserName       String?   // Chrome, Safari, Firefox, etc.
  browserVersion    String?
  
  // Network Information
  ipAddress         String
  country           String?
  city              String?
  userAgent         String    @db.Text
  
  // Trust & Security
  isTrusted         Boolean   @default(false)
  trustedAt         DateTime?
  isVerified        Boolean   @default(false)
  verifiedAt        DateTime?
  
  // Session lifecycle
  lastActivityAt    DateTime  @default(now())
  createdAt         DateTime  @default(now())
  expiresAt         DateTime

  @@unique([userId, ipAddress, userAgent])
  @@index([userId])
  @@index([sessionId])
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
  OTHER
}

// Password History for Security
model PasswordHistory {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash      String
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Login Attempts for Rate Limiting & Security
model LoginAttempt {
  id                String    @id @default(cuid())
  email             String    @db.VarChar(255)
  ipAddress         String
  success           Boolean   @default(false)
  reason            String?   // Invalid password, account locked, etc.
  userAgent         String?   @db.Text
  timestamp         DateTime  @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([timestamp])
  @@index([success])
}

// Email Verification Tokens
model EmailVerificationToken {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email             String    @db.VarChar(255) // Email to verify
  token             String    @unique
  expiresAt         DateTime
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// Password Reset Tokens
model PasswordResetToken {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token             String    @unique
  expiresAt         DateTime
  usedAt            DateTime?
  ipAddress         String?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// (User_Extended removed - relations already added to the User model above)

// ============================================================================
// ORGANIZATIONS & MULTI-TENANCY
// ============================================================================

model Organization {
  id                    String    @id @default(cuid())
  name                  String    @db.VarChar(255)
  slug                  String    @unique @db.VarChar(128)
  email                 String?   @db.VarChar(255)    // Primary contact email
  description           String?
  logo                  String?
  website               String?
  status                OrgStatus @default(ACTIVE)
  isActive              Boolean   @default(true)      // Quick active check
  tier                  SubscriptionTier @default(FREE)
  encryptionKey         String?   @db.VarChar(128)    // Per-tenant encryption key
  metadata              String?   @db.Text            // JSON additional metadata
  onboardingCompletedAt DateTime?                     // When onboarding was completed
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime? // Soft delete

  // Billing & limits
  maxMembers            Int       @default(5)
  maxProjects           Int       @default(10)
  maxStorageGB          Float     @default(5)
  usedStorageGB         Float     @default(0)

  // Relations
  members               OrganizationMember[]
  roles                 Role[]
  subscriptions         Subscription[]
  billingProfiles       BillingProfile[]
  content               Content[]
  workflows             Workflow[]
  webhooks              Webhook[]
  auditLogs             AuditLog[] @relation("OrgAudit")
  invitations           Invitation[]
  apiKeys               APIKey[]
  analyticsEvents       AnalyticsEvent[]
  features              FeatureFlag[]
  emailTemplates        EmailTemplate[]
  emails                Email[]
  notifications         Notification[]
  emailLogs             EmailLog[]
  emailSettings         AdminEmailSettings?
  
  // AI features
  aiUsages              AIUsage[]
  promptTemplates       PromptTemplate[]
  
  // Video engine
  videoProjects         VideoProject[]  @relation("OrgVideos")
  mediaAssets           MediaAsset[]    @relation("OrgMedia")

  // Social media scheduler
  socialAccounts        SocialAccount[]
  scheduledPosts        ScheduledPost[]
  bulkBatches           BulkBatch[]
  optimalPostingTimes   OptimalPostingTime[]

  // Marketing engine
  adPlatformAccounts    AdPlatformAccount[]  @relation("OrgAdAccounts")
  marketingCampaigns    MarketingCampaign[]  @relation("OrgCampaigns")
  conversionEvents      ConversionEvent[]    @relation("OrgConversions")
  funnels               Funnel[]             @relation("OrgFunnels")

  // Multi-tenant relations
  tenantDomains         DomainMapping[] @relation("TenantDomains")
  tenantUsage           TenantUsage[] @relation("TenantUsage")
  tenantRateLimits      TenantRateLimitQuota? @relation("TenantRateLimits")
  tenantRateLimitUsage  TenantRateLimitUsage[] @relation("TenantRateLimitUsage")
  tenantOnboarding      TenantOnboarding? @relation("TenantOnboarding")
  apiRateLimitState     ApiRateLimitState[] @relation("ApiRateLimitState")

  // UGC Content Generator
  ugcAvatars            UGCAvatar[]    @relation("OrgUGCAvatars")
  voiceClones           VoiceClone[]   @relation("OrgVoiceClones")
  ugcProjects           UGCProject[]   @relation("OrgUGCProjects")

  // Module 11: Teams & Collaboration
  teams                 Team[]         @relation("OrgTeams")

  // AI CEO Module
  aiCeoEnabled          Boolean          @default(false)
  aiCeoConfig           AICEOConfig?
  aiCeoDecisions        AIceoDecision[]
  aiCeoReports          AICEOReport[]

  // Credit billing
  creditAccount         CreditAccount?   @relation("OrgCreditAccount")

  // Growth engine - Lead generation
  leadSources           LeadSource[] @relation("OrgLeadSources")
  leads                 Lead[] @relation("OrgLeads")
  visitors              VisitorTrack[] @relation("OrgVisitors")

  // Growth engine - SEO & Content
  blogPosts             BlogPost[] @relation("OrgBlogPosts")
  keywordClusters       KeywordCluster[] @relation("OrgKeywordClusters")

  // Growth engine - CRM
  contacts              Contact[] @relation("OrgContacts")
  deals                 Deal[] @relation("OrgDeals")
  activities            Activity[] @relation("OrgActivities")

  // Growth engine - Marketing Automation
  marketingCampaigns    MarketingCampaign[] @relation("OrgMarketingCampaigns")
  campaignTemplates     CampaignTemplate[] @relation("OrgCampaignTemplates")
  automationWorkflows   AutomationWorkflow[] @relation("OrgAutomationWorkflows")
  aiCalling             AICalling[] @relation("OrgAICalling")

  // AI Autopilot self-growing system
  autopilotPolicies     AutopilotPolicy[] @relation("OrgAutopilotPolicies")
  autopilotRuns         AutopilotRun[] @relation("OrgAutopilotRuns")
  trafficSources        TrafficSource[] @relation("OrgTrafficSources")

  @@index([slug])
  @@index([status])
  @@index([tier])
  @@index([createdAt])
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model OrganizationMember {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId                String
  role                  Role      @relation(fields: [roleId], references: [id])
  joinedAt              DateTime  @default(now())
  invitedBy             String?   // User ID who invited
  status                MemberStatus @default(ACTIVE)

  // Denormalized for performance
  roleName              String?   // Cache role name
  permissions           String[]  @default([]) // Cached permissions as JSON

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([roleId])
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  INVITED
  PENDING_ACCEPTANCE
}

model Invitation {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedEmail          String    @db.VarChar(255)
  roleId                String
  role                  Role      @relation(fields: [roleId], references: [id])
  invitedBy             String
  invitedByUser         User      @relation(fields: [invitedBy], references: [id])
  status                InvitationStatus @default(PENDING)
  token                 String    @unique
  expiresAt             DateTime
  acceptedAt            DateTime?
  acceptedByUserId      String?
  createdAt             DateTime  @default(now())

  @@unique([organizationId, invitedEmail])
  @@index([organizationId])
  @@index([invitedEmail])
  @@index([token])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ============================================================================
// RBAC (ROLE-BASED ACCESS CONTROL)
// ============================================================================

model Role {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String    @db.VarChar(128)
  description           String?
  isSystem              Boolean   @default(false) // Cannot be deleted if true
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  permissions           Permission[]
  members               OrganizationMember[]
  invitations           Invitation[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id                    String    @id @default(cuid())
  roleId                String
  role                  Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  action                String    @db.VarChar(128) // e.g., "create:content", "delete:user"
  resource              String    @db.VarChar(128) // e.g., "content", "organization"
  createdAt             DateTime  @default(now())

  @@unique([roleId, action, resource])
  @@index([roleId])
}

// ============================================================================
// SUBSCRIPTIONS & BILLING
// ============================================================================

model Subscription {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                  BillingPlan?  @relation(fields: [planId], references: [id])
  planId                String?
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelledAt           DateTime?
  
  // Payment provider IDs (external references)
  stripeSubscriptionId  String?   @unique
  paystackSubscriptionId String?
  flutterSubscriptionId String?
  paypalSubscriptionId  String?
  sofortSubscriptionId  String?
  
  // Primary payment method
  primaryPaymentMethod  PaymentProvider @default(STRIPE)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  invoices              Invoice[]
  payments              Payment[]

  @@unique([organizationId])
  @@index([organizationId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAST_DUE
  TRIAL
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  FLUTTERWAVE
  PAYPAL
  SOFORT
  CRYPTO
}

model BillingPlan {
  id                    String    @id @default(cuid())
  name                  String    @db.VarChar(128)
  tier                  SubscriptionTier @unique
  description           String?
  pricePerMonth         Float
  pricePerYear          Float?
  maxMembers            Int
  maxProjects           Int
  maxStorageGB          Float
  features              String[]  @default([]) // JSON array of feature strings
  createdAt             DateTime  @default(now())

  subscriptions         Subscription[]

  @@index([tier])
}

model BillingProfile {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Stripe
  stripeCustomerId      String?
  
  // Paystack
  paystackCustomerId    String?
  paystackAuthCode      String?
  
  // Flutterwave
  flutterwaveCustomerId String?
  
  // PayPal
  paypalCustomerId      String?
  
  // Sofort
  sofortCustomerId      String?
  
  // Common billing info
  cardLast4             String?
  cardBrand             String?
  billingEmail          String
  billingName           String?
  billingAddress        String?
  billingCity           String?
  billingState          String?
  billingZip            String?
  billingCountry        String?
  taxId                 String?
  
  // Payment methods
  paymentMethods        PaymentMethod[]
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  invoices              Invoice[]

  @@unique([organizationId])
  @@index([organizationId])
}

model Invoice {
  id                    String    @id @default(cuid())
  subscriptionId        String
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  billingProfileId      String
  billingProfile        BillingProfile @relation(fields: [billingProfileId], references: [id])
  stripeInvoiceId       String?
  amount                Float
  currency              String    @default("USD")
  status                InvoiceStatus @default(PENDING)
  issuedAt              DateTime
  dueAt                 DateTime
  paidAt                DateTime?
  pdfUrl                String?
  createdAt             DateTime  @default(now())

  @@index([subscriptionId])
  @@index([billingProfileId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  FAILED
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

model Content {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type                  ContentType
  title                 String    @db.VarChar(255)
  description           String?   @db.Text
  slug                  String    @db.VarChar(255)
  content               String?   @db.Text // Main content/body
  creatorId             String
  creator               User      @relation("ContentCreator", fields: [creatorId], references: [id])
  status                ContentStatus @default(DRAFT)
  tags                  String[]  @default([])
  thumbnail             String?
  views                 Int       @default(0)
  likes                 Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  publishedAt           DateTime?
  scheduledAt           DateTime?
  expiresAt             DateTime?

  // Relations
  media                 Media[]
  savedBy               SavedContent[]
  workflow              Workflow?
  analyticsEvents       AnalyticsEvent[]
  activityLogs          ContentActivityLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([creatorId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
  CAROUSEL
  STORY
  REELS
  AUTOMATION_TEMPLATE
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
  DELETED
}

model Media {
  id                    String    @id @default(cuid())
  contentId             String
  content               Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  organizationId        String
  type                  MediaType
  fileName              String
  fileSize              BigInt
  mimeType              String
  url                   String    @db.Text // S3 URL
  duration              Int?      // For videos (seconds)
  width                 Int?      // Image/video
  height                Int?      // Image/video
  metadata              String?   @db.Text // JSON
  uploadedAt            DateTime  @default(now())

  @@index([contentId])
  @@index([organizationId])
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  THUMBNAIL
}

model SavedContent {
  id                    String    @id @default(cuid())
  organizationId        String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId             String
  content               Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  folder                String?   @default("saved")
  savedAt               DateTime  @default(now())

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
}

// ============================================================================
// MARKETING AUTOMATION
// ============================================================================

model Workflow {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String    @db.VarChar(255)
  description           String?
  type                  WorkflowType
  trigger               String    @db.Text // JSON: Configuration for trigger
  actions               WorkflowAction[]
  isActive              Boolean   @default(false)
  contentId             String?   @unique
  content               Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)
  executionCount        Int       @default(0)
  lastExecutedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([organizationId])
  @@index([type])
}

enum WorkflowType {
  SCHEDULING
  CONDITIONAL
  SEQUENCE
  TRIGGER_BASED
  WEBHOOK
}

model WorkflowAction {
  id                    String    @id @default(cuid())
  workflowId            String
  workflow              Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order                 Int
  actionType            String    // e.g., "publish", "email", "webhook"
  config                String    @db.Text // JSON configuration
  createdAt             DateTime  @default(now())

  @@index([workflowId])
}

// ============================================================================
// ANALYTICS & TRACKING
// ============================================================================

model AnalyticsEvent {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentId             String?
  content               Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)
  eventType             String    @db.VarChar(128) // view, like, share, comment, etc.
  userId                String?   // Nullable for anonymous events
  properties            String?   @db.Text // JSON: Custom event properties
  timestamp             DateTime  @default(now())


  @@index([organizationId])
  @@index([contentId])
  @@index([eventType])
  @@index([timestamp])
}

// ============================================================================
// API & WEBHOOKS
// ============================================================================

model APIKey {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String    @db.VarChar(255)
  key                   String    @unique @db.Text // Hashed
  lastUsedAt            DateTime?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  revokedAt             DateTime?

  @@index([organizationId])
  @@index([userId])
}

model Webhook {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url                   String    @db.Text
  events                String[]  @default([]) // Events to subscribe to
  isActive              Boolean   @default(true)
  secret                String
  failureCount          Int       @default(0)
  lastFailedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([organizationId])
}

// ============================================================================
// PAYMENTS & TRANSACTIONS (Phase 2)
// ============================================================================

model PaymentMethod {
  id                    String    @id @default(cuid())
  billingProfileId      String
  billingProfile        BillingProfile @relation(fields: [billingProfileId], references: [id], onDelete: Cascade)
  provider              PaymentProvider
  
  // External references
  stripePaymentMethodId String?
  paystackAuthCode      String?
  flutterwaveTokenId    String?
  paypalTokenId         String?
  sofortToken           String?
  
  // Card details
  last4                 String?
  brand                 String?
  expiryMonth           Int?
  expiryYear            Int?
  
  // Bank/Account details
  accountHolderName     String?
  accountLast4          String?
  bankCode              String?
  
  // Status
  isDefault             Boolean   @default(false)
  isActive              Boolean   @default(true)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([billingProfileId])
  @@index([provider])
}

model Payment {
  id                    String    @id @default(cuid())
  subscriptionId        String
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  invoiceId             String?
  
  // Payment details
  provider              PaymentProvider
  externalPaymentId     String?   // Stripe charge ID, Paystack reference, etc.
  amount                Float
  currency              String    @default("USD")
  status                PaymentStatus @default(PENDING)
  
  // Metadata for each provider
  providerResponse      String?   @db.Text // JSON response from provider
  
  // Retry logic
  attemptNumber         Int       @default(1)
  maxRetries            Int       @default(3)
  nextRetryAt           DateTime?
  failureReason         String?
  
  // Refund
  refunds               PaymentRefund[]
  refundedAmount        Float     @default(0)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  paidAt                DateTime?

  @@unique([externalPaymentId])
  @@index([subscriptionId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

model PaymentRefund {
  id                    String    @id @default(cuid())
  paymentId             String
  payment               Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  provider              PaymentProvider
  externalRefundId      String?   // Refund ID from provider
  amount                Float
  currency              String    @default("USD")
  status                RefundStatus @default(PENDING)
  reason                String?   @db.Text
  
  providerResponse      String?   @db.Text // JSON response
  
  createdAt             DateTime  @default(now())
  completedAt           DateTime?

  @@index([paymentId])
  @@index([status])
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model PaymentWebhook {
  id                    String    @id @default(cuid())
  provider              PaymentProvider
  externalWebhookId     String?   @unique
  eventType             String    @db.VarChar(128) // payment.completed, payment.failed, etc.
  subscriptionId        String?
  paymentId             String?
  data                  String    @db.Text // Raw JSON webhook data
  status                WebhookStatus @default(RECEIVED)
  processedAt           DateTime?
  errorMessage          String?
  
  createdAt             DateTime  @default(now())

  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

// ============================================================================
// AUDIT LOGGING & COMPLIANCE
// ============================================================================

model AuditLog {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation("OrgAudit", fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation("UserAudit", fields: [userId], references: [id])
  action                String    @db.VarChar(128) // e.g., "created", "updated", "deleted"
  resource              String    @db.VarChar(128) // e.g., "content", "user"
  resourceId            String?
  changes               String?   @db.Text // JSON: Before/after values
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime  @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// NOTIFICATIONS & USER PREFERENCES
// ============================================================================

model NotificationSettings {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications    Boolean   @default(true)
  pushNotifications     Boolean   @default(true)
  inAppNotifications    Boolean   @default(true)
  weeklyDigest          Boolean   @default(true)
  marketingEmails       Boolean   @default(false)
  updatedAt             DateTime  @updatedAt
}

// ============================================================================
// FEATURE FLAGS (for A/B testing & gradual rollouts)
// ============================================================================

model FeatureFlag {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flag                  String    @db.VarChar(128) // e.g., "new_video_editor"
  enabled               Boolean   @default(false)
  rolloutPercentage     Int       @default(0) // 0-100
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([organizationId, flag])
  @@index([organizationId])
}

// ============================================================================
// EMAIL & NOTIFICATIONS (Phase 3)
// ============================================================================

model EmailTemplate {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name                  String    @db.VarChar(128) // e.g., "welcome", "payment_receipt"
  subject               String    @db.VarChar(255)
  htmlTemplate          String    @db.Text
  textTemplate          String?   @db.Text
  
  variables             String[]  @default([]) // e.g., ["{{firstName}}", "{{amount}}"]
  category              String    @db.VarChar(64) // auth, payment, notification, marketing
  
  isActive              Boolean   @default(true)
  isSystem              Boolean   @default(false) // Cannot be deleted
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  usageCount            Int       @default(0)

  emails                Email[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([category])
}

model Email {
  id                    String    @id @default(cuid())
  
  // Recipient
  toEmail               String    @db.VarChar(255)
  toName                String?   @db.VarChar(255)
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Content
  templateId            String?
  template              EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  
  subject               String    @db.VarChar(255)
  htmlContent           String?   @db.Text
  textContent           String?   @db.Text
  
  // Status tracking
  status                EmailStatus @default(PENDING)
  provider              EmailProvider @default(SENDGRID)
  externalEmailId       String?   @unique // Provider's email ID
  
  // Metadata
  relationType          String?   @db.VarChar(64) // "user", "payment", "subscription"
  relationId            String?   // Related entity ID
  
  // Delivery
  sentAt                DateTime?
  deliveredAt           DateTime?
  openedAt              DateTime?
  clickedAt             DateTime?
  bouncedAt             DateTime?
  spamReportedAt        DateTime?
  
  // Retry logic
  attemptNumber         Int       @default(1)
  maxRetries            Int       @default(3)
  nextRetryAt           DateTime?
  failureReason         String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  logs                  EmailLog[]

  @@index([organizationId])
  @@index([status])
  @@index([provider])
  @@index([toEmail])
  @@index([createdAt])
}

enum EmailStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  SPAM
  OPENED
}

enum EmailProvider {
  SENDGRID
  MAILGUN
  SES
  POSTMARK
  SENDMAIL
  SMTP
}

model Notification {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String?
  user                  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type                  NotificationType
  title                 String    @db.VarChar(255)
  message               String    @db.Text
  data                  String?   @db.Text // JSON
  
  // Delivery channels
  emailSent             Boolean   @default(false)
  pushSent              Boolean   @default(false)
  inAppCreated          Boolean   @default(true)
  
  // Status
  isRead                Boolean   @default(false)
  readAt                DateTime?
  
  // Reference
  relatedType           String?   @db.VarChar(64)
  relatedId             String?
  
  createdAt             DateTime  @default(now())
  expiresAt             DateTime? // Auto-delete old notifications

  @@index([organizationId])
  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  WELCOME
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_EXPIRING
  CONTENT_PUBLISHED
  SYSTEM_ALERT
  MARKETING
  CUSTOM
}

model EmailLog {
  id                    String    @id @default(cuid())
  emailId               String
  email                 Email?    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  event                 String    @db.VarChar(64) // sent, delivered, open, click, bounce, spam
  timestamp             DateTime
  metadata              String?   @db.Text // JSON
  
  @@index([emailId])
  @@index([organizationId])
  @@index([event])
  @@index([timestamp])
}

// ============================================================================
// ADMIN SETTINGS (Email & System Configuration)
// ============================================================================

model AdminEmailSettings {
  id                    String    @id @default(cuid())
  organizationId        String    @unique
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Primary Provider Configuration
  primaryProvider       String    @db.VarChar(64) @default("sendgrid") // sendgrid, mailgun, ses, postmark, smtp, sendmail
  
  // SendGrid Config
  sendgridApiKey        String?   @db.VarChar(1024) // Encrypted
  sendgridWebhookSecret String?   @db.VarChar(1024) // Encrypted
  sendgridDomain        String?   @db.VarChar(255)
  
  // Mailgun Config
  mailgunApiKey         String?   @db.VarChar(1024) // Encrypted
  mailgunDomain         String?   @db.VarChar(255)
  
  // AWS SES Config
  awsAccessKeyId        String?   @db.VarChar(1024) // Encrypted
  awsSecretAccessKey    String?   @db.VarChar(1024) // Encrypted
  awsRegion             String?   @db.VarChar(64) @default("us-east-1")
  
  // Postmark Config
  postmarkApiKey        String?   @db.VarChar(1024) // Encrypted
  postmarkDomain        String?   @db.VarChar(255)
  
  // SMTP Config
  smtpHost              String?   @db.VarChar(255)
  smtpPort              Int?      @default(587)
  smtpSecure            Boolean?  @default(false)
  smtpUser              String?   @db.VarChar(255)
  smtpPassword          String?   @db.VarChar(1024) // Encrypted
  
  // Sendmail Config
  sendmailPath          String?   @db.VarChar(255) @default("/usr/sbin/sendmail")
  
  // General Email Settings
  emailFrom             String    @db.VarChar(255) @default("noreply@belsuite.com")
  emailFromName         String    @db.VarChar(255) @default("Belsuite")
  replyTo               String?   @db.VarChar(255)
  
  // Failover Configuration
  enableFailover        Boolean   @default(true)
  fallbackProviders     String[]  @default(["mailgun", "seq", "postmark"]) // Order matters
  maxRetries            Int       @default(3)
  retryDelayMs          Int       @default(5000)
  
  // Rate Limiting
  rateLimitPerMinute    Int       @default(100)
  rateLimitPerHour      Int       @default(10000)
  
  // Features
  trackingEnabled       Boolean   @default(true)
  webhooksEnabled       Boolean   @default(true)
  attachmentsEnabled    Boolean   @default(true)
  
  // Audit & Compliance
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  updatedBy             String?   // User ID who updated settings
  lastTestedAt          DateTime?  // Last test email sent
  testStatus            String?   // Success or error message

  @@index([organizationId])
  @@index([primaryProvider])
  @@index([updatedAt])
}

// ============================================================================
// MULTI-TENANT ARCHITECTURE - DOMAIN MAPPING & TENANT MANAGEMENT
// ============================================================================


model DomainMapping {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation("TenantDomains", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Domain information
  domain                String?   @unique @db.VarChar(255) // Full domain (acme.belsuite.com or acme-corp.com)
  domainType            DomainType @default(SUBDOMAIN) // SUBDOMAIN or CUSTOM
  subdomain             String?   @unique @db.VarChar(128) // For subdomains: "acme"
  baseDomain            String?   @db.VarChar(255) // For custom domains: the base configured domain
  
  // SSL/TLS Configuration
  sslCertificate        String?   @db.Text // Encrypted SSL cert
  sslPrivateKey         String?   @db.Text // Encrypted private key
  sslExpiresAt          DateTime?
  certificateProvider   String    @db.VarChar(64) @default("letsencrypt") // letsencrypt, manual, etc.
  
  // DNS Verification (for custom domains)
  dnsCnameRecord        String?   @db.VarChar(255)   // CNAME target to point at
  dnsVerificationToken  String?   @db.VarChar(128)   // Token placed in TXT record
  dnsVerificationRecord String?   @db.VarChar(255)   // Full TXT record value
  dnsVerified           Boolean   @default(false)
  dnsVerifiedAt         DateTime?
  sslVerified           Boolean   @default(false)    // SSL/TLS provisioned & valid

  // Status & Lifecycle
  isActive              Boolean   @default(true)
  isPrimary             Boolean   @default(false) // Primary domain for the tenant

  // Redirects
  redirectTo            String?   @db.VarChar(255) // Redirect to another domain
  redirectUrl           String?   @db.VarChar(255) // Alias for redirectTo
  
  // Audit & Compliance
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  verifiedBy            String?   // User who verified
  verifiedAt            DateTime?

  @@unique([organizationId, domainType, subdomain])
  @@index([organizationId])
  @@index([domain])
  @@index([subdomain])
  @@index([isActive])
  @@index([isPrimary])
}

enum DomainType {
  SUBDOMAIN    // tenant.belsuite.com
  CUSTOM       // tenant.com or www.tenant.com
}


model TenantUsage {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation("TenantUsage", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Time period tracking
  period                String    @db.VarChar(10) // YYYY-MM (monthly breakdown)
  startDate             DateTime
  endDate               DateTime
  
  // AI Usage
  aiTokensUsed          Int       @default(0)
  aiRequestsCount       Int       @default(0)
  
  // Storage Usage
  storageUsedBytes      BigInt    @default(0)
  
  // API Usage
  apiCallsCount         Int       @default(0)
  apiErrorCount         Int       @default(0)
  
  // Email Usage
  emailsSent            Int       @default(0)
  emailsDelivered       Int       @default(0)
  emailsBounced         Int       @default(0)
  emailsOpened          Int       @default(0)
  emailsClicked         Int       @default(0)
  
  // Content/Features Usage
  contentCount          Int       @default(0)
  activeUsers           Int       @default(0)
  
  // Cost Calculation
  estimatedCost         Float     @default(0) // In USD
  
  // Metadata
  metadata              String?   @db.Text // JSON for additional metrics
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([organizationId, period])
  @@index([organizationId])
  @@index([period])
  @@index([startDate])
}


model TenantRateLimitQuota {
  id                    String    @id @default(cuid())
  organizationId        String    @unique
  organization          Organization @relation("TenantRateLimits", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // API Rate Limits
  apiRequestsPerMinute  Int       @default(100)
  apiRequestsPerHour    Int       @default(10000)
  apiRequestsPerDay     Int       @default(1000000)
  
  // Email Rate Limits
  emailsPerMinute       Int       @default(100)
  emailsPerHour         Int       @default(10000)
  emailsPerDay          Int       @default(1000000)
  
  // AI/ML Rate Limits
  aiTokensPerMinute     Int       @default(5000)
  aiTokensPerHour       Int       @default(500000)
  aiTokensPerDay        Int       @default(10000000)
  
  // Storage Limits (in GB)
  maxStorageGB          Float     @default(10)
  
  // Concurrent Connections
  maxConcurrentRequests Int       @default(100)
  maxConcurrentUploads  Int       @default(10)
  
  // Custom Limits
  customLimits          String?   @db.Text // JSON for additional limits
  
  // Enforcement
  enforceRateLimits     Boolean   @default(true)
  softLimitNotifyAt     Int       @default(80) // Notify at 80% of limit
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  effectiveFrom         DateTime  @default(now())
  effectiveUntil        DateTime? // Null = indefinite

  @@index([organizationId])
  @@index([effectiveFrom])
}


model TenantRateLimitUsage {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation("TenantRateLimitUsage", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Period tracking
  period                String    @db.VarChar(20) // "MINUTE", "HOUR", "DAY"
  periodStart           DateTime
  periodEnd             DateTime
  
  // Current usage
  apiRequestsUsed       Int       @default(0)
  emailsUsed            Int       @default(0)
  aiTokensUsed          Int       @default(0)
  storageUsedGB         Float     @default(0)
  concurrentRequests    Int       @default(0)
  concurrentUploads     Int       @default(0)
  
  // Violation tracking
  limitExceededCount    Int       @default(0)
  lastExceededAt        DateTime?
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([organizationId, period, periodStart])
  @@index([organizationId])
  @@index([periodStart])
  @@index([period])
}


model TenantOnboarding {
  id                    String    @id @default(cuid())
  organizationId        String    @unique
  organization          Organization @relation("TenantOnboarding", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Onboarding Steps
  step                  OnboardingStep @default(WELCOME)
  completed             Boolean   @default(false)
  completedAt           DateTime?
  
  // Information Collected
  companyName           String?
  companyWebsite        String?
  companyLogo           String?   // URL
  industry              String?
  
  // Domain Setup
  subdomainChosen       String?
  customDomainChosen    String?
  
  // Initial Settings
  defaultLanguage       String    @default("en")
  defaultTimezone       String    @default("UTC")
  
  // Payment Setup
  billingMethodAdded    Boolean   @default(false)
  paymentMethodId       String?
  
  // Team Invitation
  teamMembersInvited    Boolean   @default(false)
  invitedMembersCount   Int       @default(0)
  
  // Feature Activation
  featurePreferences    String?   @db.Text // JSON
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  startedAt             DateTime  @default(now())
  abandonedAt           DateTime?

  @@index([organizationId])
  @@index([step])
  @@index([completed])
}

enum OnboardingStep {
  WELCOME
  COMPANY_INFO
  DOMAIN_SETUP
  TEAM_SETUP
  PAYMENT_SETUP
  FEATURE_SELECTION
  COMPLETED
}


model ApiRateLimitState {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation("ApiRateLimitState", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Request tracking
  requestCount          Int       @default(0) // Current requests in this minute
  requestTimestamp      DateTime
  
  // Violation tracking
  violationCount        Int       @default(0)
  blockedUntil          DateTime?
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([organizationId, requestTimestamp])
  @@index([organizationId])
  @@index([requestTimestamp])
}

// ============================================================================
// AI FEATURES
// ============================================================================


model AIUsage {
  id                    String    @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Model & Provider
  model                 String    @db.VarChar(128) // e.g., "gpt-4-turbo", "claude-3-opus"
  provider              String    @db.VarChar(64)  // e.g., "openai", "anthropic", "local"
  
  // Usage metrics
  inputTokens           Int       @default(0)
  outputTokens          Int       @default(0)
  totalTokens           Int       @default(0)
  cost                  Float     @default(0)      // USD
  
  // Content type
  contentType           String?   @db.VarChar(128) // e.g., "blog_post", "social_post", "image"
  promptTemplateId      String?
  promptTemplate        PromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  
  // Cache info
  usedCache             Boolean   @default(false)
  cacheHitTimestamp     DateTime?
  
  // Response metrics
  responseTime          Int?      // milliseconds
  success               Boolean   @default(true)
  errorMessage          String?
  
  // Timestamps
  createdAt             DateTime  @default(now())
  
  @@index([organizationId])
  @@index([userId])
  @@index([model])
  @@index([provider])
  @@index([contentType])
  @@index([createdAt])
}


model PromptTemplate {
  id                    String    @id @default(cuid())
  organizationId        String?
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name                  String    @db.VarChar(255)
  description           String?   @db.Text
  category              String    @db.VarChar(128) // e.g., "blog", "social", "email"
  
  // Template content
  prompt                String    @db.Text
  variables             String[]  @default([]) // JSON array of variable names
  
  // System metadata
  isBuiltIn             Boolean   @default(false)  // Built-in vs user-created
  createdBy             String?
  user                  User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  
  // Usage & optimization
  usageCount            Int       @default(0)
  averageTokens         Int?
  averageCost           Float?
  
  // Status
  isActive              Boolean   @default(true)
  isPublic              Boolean   @default(false)  // Org-wide template
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  usages                AIUsage[]
  versions              PromptVersion[]  // Prompt evolution versioning

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([category])
  @@index([isBuiltIn])
  @@index([createdAt])
}

// ============================================================================
// UPDATE ORGANIZATION MODEL WITH TENANT FIELDS
// ============================================================================

// Note: The Organization model has been enhanced with these fields already:
// - Tenant-related fields for multi-tenancy support
// - Relations: TenantDomains, TenantUsage, TenantRateLimits, TenantRateLimitUsage, TenantOnboarding, ApiRateLimitState
// - See Organization model above for full details

// ============================================================================
// VIDEO ENGINE - AI Video Creation & Editing (CapCut-style)
// ============================================================================

enum VideoStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum VideoJobType {
  RENDER          // Full render from timeline
  GENERATE_SCENE  // AI scene generation
  GENERATE_AUDIO  // TTS voiceover
  GENERATE_SUBS   // Auto-subtitle extraction
  TRANSCODE       // Format conversion
  THUMBNAIL       // Thumbnail generation
}

enum VideoJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum VideoMediaType {
  VIDEO_CLIP
  AUDIO_CLIP
  IMAGE
  SUBTITLE_TRACK
  VOICEOVER
  BACKGROUND_MUSIC
}

// A video project (the main unit of work)
model VideoProject {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation("OrgVideos", fields: [organizationId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User         @relation("UserVideos", fields: [createdById], references: [id])

  title           String       @db.VarChar(255)
  description     String?      @db.Text
  script          String?      @db.Text   // Raw script used for generation
  status          VideoStatus  @default(DRAFT)

  // Output file details (set when render completes)
  outputUrl       String?      @db.Text
  thumbnailUrl    String?      @db.Text
  durationMs      Int?                    // milliseconds
  fileSizeBytes   BigInt?

  // Timeline state — stored as JSON blob
  timelineJson    String?      @db.Text   // serialised TimelineState

  // Resolution / format
  width           Int          @default(1920)
  height          Int          @default(1080)
  fps             Int          @default(30)
  format          String       @default("mp4") @db.VarChar(16)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  mediaAssets     MediaAsset[]
  processingJobs  VideoJob[]
  scenes          VideoScene[]
  subtitleTracks  SubtitleTrack[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

// Individual media asset (clip, image, audio) in the library
model MediaAsset {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation("OrgMedia", fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedById    String
  uploadedBy      User         @relation("UserMedia", fields: [uploadedById], references: [id])
  videoProjectId  String?
  videoProject    VideoProject? @relation(fields: [videoProjectId], references: [id], onDelete: SetNull)

  name            String       @db.VarChar(255)
  mediaType       VideoMediaType
  mimeType        String       @db.VarChar(128)
  storageKey      String       @db.Text   // S3/storage path
  publicUrl       String?      @db.Text
  fileSizeBytes   BigInt?
  durationMs      Int?                    // audio/video only
  width           Int?                    // video/image
  height          Int?

  // AI generation metadata
  aiGenerated     Boolean      @default(false)
  aiPrompt        String?      @db.Text

  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([videoProjectId])
  @@index([mediaType])
}

// A scene in the video (maps to a section of the timeline)
model VideoScene {
  id              String       @id @default(cuid())
  videoProjectId  String
  videoProject    VideoProject @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  order           Int                     // Scene order (0-based)
  scriptSegment   String?      @db.Text   // Script text for this scene
  durationMs      Int          @default(5000)

  // Visual
  backgroundUrl   String?      @db.Text
  aiImagePrompt   String?      @db.Text   // Prompt used to generate background

  // Voiceover
  voiceoverUrl    String?      @db.Text
  voiceoverText   String?      @db.Text
  ttsVoiceId      String?      @db.VarChar(128)  // ElevenLabs / OpenAI voice id

  // Overlays / text stored as JSON
  overlaysJson    String?      @db.Text

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([videoProjectId])
  @@index([order])
}

// Subtitle track for a project
model SubtitleTrack {
  id              String       @id @default(cuid())
  videoProjectId  String
  videoProject    VideoProject @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  language        String       @default("en") @db.VarChar(16)
  srtContent      String?      @db.Text   // Full SRT file content
  vttContent      String?      @db.Text   // WebVTT content
  storageKey      String?      @db.Text   // path to stored file

  autoGenerated   Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ============================================================================
// MARKETING ENGINE — AI Ad Generation, Campaigns, A/B Tests, Funnels
// ============================================================================

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignObjective {
  AWARENESS       // Reach / impressions
  TRAFFIC         // Clicks to website
  ENGAGEMENT      // Likes, comments, shares
  LEADS           // Lead generation form
  CONVERSIONS     // Purchase / sign-up
  APP_INSTALLS    // Mobile app installs
  VIDEO_VIEWS     // Video play events
}

enum AdPlatform {
  FACEBOOK
  INSTAGRAM
  GOOGLE_SEARCH
  GOOGLE_DISPLAY
  GOOGLE_YOUTUBE
  TIKTOK_ADS
  LINKEDIN_ADS
  TWITTER_ADS
}

enum AdFormat {
  SINGLE_IMAGE
  CAROUSEL
  VIDEO
  COLLECTION
  STORY
  RESPONSIVE_SEARCH    // Google RSA
  RESPONSIVE_DISPLAY   // Google GDN
}

enum AdStatus {
  DRAFT
  IN_REVIEW
  ACTIVE
  PAUSED
  REJECTED
  COMPLETED
}

enum ABTestStatus {
  DRAFT
  RUNNING
  CONCLUDED
  ARCHIVED
}

enum FunnelStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConversionEventType {
  PAGE_VIEW
  CLICK
  FORM_SUBMIT
  PURCHASE
  SIGNUP
  DOWNLOAD
  PHONE_CALL
  VIDEO_PLAY
  CUSTOM
}

// ─── Ad Platform Accounts (Facebook Ads Manager, Google Ads) ─────────────────

model AdPlatformAccount {
  id               String      @id @default(cuid())
  organizationId   String
  organization     Organization @relation("OrgAdAccounts", fields: [organizationId], references: [id], onDelete: Cascade)

  platform         AdPlatform
  accountId        String      @db.VarChar(128)  // platform's account ID
  accountName      String      @db.VarChar(255)
  currencyCode     String      @default("USD") @db.VarChar(8)
  timezone         String      @default("UTC")

  // Encrypted OAuth tokens
  accessToken      String      @db.Text
  refreshToken     String?     @db.Text
  tokenExpiresAt   DateTime?

  isActive         Boolean     @default(true)
  syncedAt         DateTime?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  campaigns        MarketingCampaign[]

  @@unique([organizationId, platform, accountId])
  @@index([organizationId])
  @@index([platform])
}

// ─── Marketing Campaign ───────────────────────────────────────────────────────

model MarketingCampaign {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation("OrgCampaigns", fields: [organizationId], references: [id], onDelete: Cascade)
  adAccountId      String?
  adAccount        AdPlatformAccount? @relation(fields: [adAccountId], references: [id], onDelete: SetNull)

  name             String            @db.VarChar(255)
  description      String?           @db.Text
  objective        CampaignObjective
  status           CampaignStatus    @default(DRAFT)

  // Budget
  dailyBudget      Float?            // USD
  totalBudget      Float?            // USD
  spentBudget      Float             @default(0)

  // Schedule
  startDate        DateTime?
  endDate          DateTime?

  // Target audience (JSON blob: age, gender, interests, locations, lookalike)
  audienceJson     String?           @db.Text

  // Platform campaign ID (set after sync)
  platformCampaignId String?         @db.VarChar(255)

  // AI metadata
  aiGenerated      Boolean           @default(false)
  aiNotes          String?           @db.Text

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  ads              Ad[]
  abTests          ABTest[]
  performanceSnapshots CampaignPerformance[]

  @@index([organizationId])
  @@index([status])
  @@index([startDate])
}

// ─── Ad ──────────────────────────────────────────────────────────────────────

model Ad {
  id               String            @id @default(cuid())
  campaignId       String
  campaign         MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name             String            @db.VarChar(255)
  format           AdFormat
  status           AdStatus          @default(DRAFT)

  // Copy
  headline         String?           @db.VarChar(512)
  body             String?           @db.Text
  callToAction     String?           @db.VarChar(64)  // "Shop Now", "Learn More"
  destinationUrl   String?           @db.Text

  // Creative assets (JSON array of URLs / storage keys)
  creativeAssets   String?           @db.Text  // JSON: [{type, url, altText}]

  // AI generation
  aiGenerated      Boolean           @default(false)
  aiPrompt         String?           @db.Text
  aiScore          Float?            // AI-predicted quality score 0-100

  // Platform ad ID (set after sync)
  platformAdId     String?           @db.VarChar(255)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  variants         AdVariant[]
  impressions      AdPerformance[]
  conversions      ConversionEvent[]

  @@index([campaignId])
  @@index([status])
}

// ─── Ad Variant (A/B test copy variant) ──────────────────────────────────────

model AdVariant {
  id               String    @id @default(cuid())
  adId             String
  ad               Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)
  abTestId         String?
  abTest           ABTest?   @relation(fields: [abTestId], references: [id], onDelete: SetNull)

  label            String    @db.VarChar(64)  // "A", "B", "C"
  headline         String?   @db.VarChar(512)
  body             String?   @db.Text
  callToAction     String?   @db.VarChar(64)
  creativeAssets   String?   @db.Text  // JSON array

  // Metrics (live aggregated)
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  conversions      Int       @default(0)
  spend            Float     @default(0)

  isWinner         Boolean   @default(false)
  isControl        Boolean   @default(false)  // The baseline variant

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([adId])
  @@index([abTestId])
}

// ─── A/B Test ─────────────────────────────────────────────────────────────────

model ABTest {
  id               String           @id @default(cuid())
  campaignId       String
  campaign         MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name             String           @db.VarChar(255)
  hypothesis       String?          @db.Text
  metric           String           @db.VarChar(64)  // "ctr", "cpc", "cvr", "roas"
  status           ABTestStatus     @default(DRAFT)

  // Statistical parameters
  confidenceLevel  Float            @default(0.95)   // 95%
  minimumSampleSize Int             @default(1000)
  trafficSplit     String           @db.Text          // JSON: {"A": 50, "B": 50}

  // Results
  winnerVariantId  String?
  pValue           Float?
  statisticalPower Float?
  conclusionNotes  String?          @db.Text

  startedAt        DateTime?
  concludedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  variants         AdVariant[]

  @@index([campaignId])
  @@index([status])
}

// ─── Campaign Performance Snapshot ───────────────────────────────────────────

model CampaignPerformance {
  id               String            @id @default(cuid())
  campaignId       String
  campaign         MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date             DateTime          @db.Date     // Daily snapshot date
  impressions      Int               @default(0)
  clicks           Int               @default(0)
  conversions      Int               @default(0)
  spend            Float             @default(0)
  revenue          Float             @default(0)

  // Derived (computed on write)
  ctr              Float             @default(0)  // clicks/impressions
  cpc              Float             @default(0)  // spend/clicks
  cpa              Float             @default(0)  // spend/conversions
  roas             Float             @default(0)  // revenue/spend

  // Breakdown by platform (JSON: {FACEBOOK: {...}, GOOGLE: {...}})
  platformBreakdown String?          @db.Text

  createdAt        DateTime          @default(now())

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

// ─── Ad Performance (per-ad per-day) ─────────────────────────────────────────

model AdPerformance {
  id               String    @id @default(cuid())
  adId             String
  ad               Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)
  date             DateTime  @db.Date

  impressions      Int       @default(0)
  clicks           Int       @default(0)
  conversions      Int       @default(0)
  spend            Float     @default(0)
  revenue          Float     @default(0)
  frequency        Float     @default(0)  // avg times shown per user

  createdAt        DateTime  @default(now())

  @@unique([adId, date])
  @@index([adId])
  @@index([date])
}

// ─── Conversion Event ─────────────────────────────────────────────────────────

model ConversionEvent {
  id               String              @id @default(cuid())
  organizationId   String
  organization     Organization        @relation("OrgConversions", fields: [organizationId], references: [id], onDelete: Cascade)
  adId             String?
  ad               Ad?                 @relation(fields: [adId], references: [id], onDelete: SetNull)

  eventType        ConversionEventType
  eventName        String?             @db.VarChar(128)  // Custom event name
  funnelPageId     String?

  // Attribution
  utmSource        String?             @db.VarChar(128)
  utmMedium        String?             @db.VarChar(128)
  utmCampaign      String?             @db.VarChar(255)
  utmContent       String?             @db.VarChar(255)
  utmTerm          String?             @db.VarChar(255)
  clickId          String?             @db.VarChar(255)  // fbclid / gclid

  // Session / visitor
  sessionId        String?             @db.VarChar(255)
  visitorId        String?             @db.VarChar(255)  // anonymous fingerprint
  ipAddress        String?             @db.VarChar(64)
  userAgent        String?             @db.Text
  referrer         String?             @db.Text
  pageUrl          String?             @db.Text

  // Value
  value            Float?              // monetary conversion value
  currency         String?             @db.VarChar(8)

  // Raw payload for custom events
  metadataJson     String?             @db.Text

  occurredAt       DateTime            @default(now())

  @@index([organizationId])
  @@index([adId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([utmCampaign])
}

// ─── Funnel ───────────────────────────────────────────────────────────────────

model Funnel {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation("OrgFunnels", fields: [organizationId], references: [id], onDelete: Cascade)

  name             String        @db.VarChar(255)
  description      String?       @db.Text
  status           FunnelStatus  @default(DRAFT)

  // Custom domain / slug
  slug             String        @db.VarChar(128)
  domain           String?       @db.VarChar(255)

  // Global styles (JSON: colors, fonts, borders)
  themeJson        String?       @db.Text

  aiGenerated      Boolean       @default(false)

  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  pages            FunnelPage[]
  metrics          FunnelMetrics[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
}

// ─── Funnel Page ──────────────────────────────────────────────────────────────

model FunnelPage {
  id               String    @id @default(cuid())
  funnelId         String
  funnel           Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  order            Int                   // Step number (0 = opt-in, 1 = upsell, etc.)
  pageType         String    @db.VarChar(64)  // "optin", "salespage", "upsell", "thankyou"
  title            String    @db.VarChar(255)
  slug             String    @db.VarChar(128)

  // Page content as block-based JSON (similar to Notion blocks)
  blocksJson       String?   @db.Text

  // Conversion element
  ctaText          String?   @db.VarChar(128)
  ctaUrl           String?   @db.Text
  nextPageId       String?   @db.VarChar(255) // nextStep within funnel

  // Tracking
  views            Int       @default(0)
  conversions      Int       @default(0)

  // SEO
  metaTitle        String?   @db.VarChar(255)
  metaDescription  String?   @db.Text

  aiGenerated      Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([funnelId, slug])
  @@index([funnelId])
  @@index([order])
}

// ─── Funnel Metrics (event stream) ───────────────────────────────────────────

model FunnelMetrics {
  id               String    @id @default(cuid())
  funnelId         String
  funnel           Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  date             DateTime  @db.Date
  pageId           String?   @db.VarChar(255)

  views            Int       @default(0)
  uniqueVisitors   Int       @default(0)
  conversions      Int       @default(0)
  exits            Int       @default(0)
  bounces          Int       @default(0)
  avgTimeOnPage    Float     @default(0)  // seconds

  createdAt        DateTime  @default(now())

  @@unique([funnelId, date, pageId])
  @@index([funnelId])
  @@index([date])
}

// Background processing job for video operations
model VideoJob {
  id              String          @id @default(cuid())
  videoProjectId  String
  videoProject    VideoProject    @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  jobType         VideoJobType
  status          VideoJobStatus  @default(QUEUED)
  bullJobId       String?         @db.VarChar(255)  // BullMQ job id
  progress        Int             @default(0)       // 0-100

  // Input/output stored as JSON
  inputJson       String?         @db.Text
  outputJson      String?         @db.Text
  errorMessage    String?         @db.Text

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@index([videoProjectId])
  @@index([status])
  @@index([jobType])
  @@index([createdAt])
}

// ============================================================================
// SOCIAL MEDIA SCHEDULER
// ============================================================================

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  TWITTER
  LINKEDIN
  PINTEREST
  WHATSAPP
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum PublishStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum BulkBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

// Connected social media account (one per platform per user per org)
model SocialAccount {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         SocialPlatform
  platformUserId   String
  platformUsername String?
  displayName      String?
  avatar           String?
  accessToken      String         @db.Text // AES-256-GCM encrypted
  refreshToken     String?        @db.Text // AES-256-GCM encrypted
  tokenExpiresAt   DateTime?
  scope            String?
  pageId           String?        // Facebook/Instagram page ID
  pageName         String?
  isActive         Boolean        @default(true)
  metadata         Json?          // Extra platform-specific data (e.g., WhatsApp recipients list)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  posts            ScheduledPostAccount[]
  publishResults   PostPublishResult[]

  @@unique([organizationId, platform, platformUserId])
  @@index([organizationId])
  @@index([userId])
  @@index([platform])
}

// A scheduled (or published) social post
model ScheduledPost {
  id                  String         @id @default(cuid())
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById         String
  createdBy           User           @relation(fields: [createdById], references: [id])
  content             String         @db.Text
  mediaUrls           String[]       @default([]) // CDN URLs
  mediaKeys           String[]       @default([]) // S3 keys
  link                String?
  hashtags            String[]       @default([])
  status              PostStatus     @default(DRAFT)
  scheduledAt         DateTime?
  publishedAt         DateTime?

  // AI creation metadata
  aiGenerated         Boolean        @default(false)
  aiPrompt            String?        @db.Text
  optimalTimeUsed     Boolean        @default(false)

  // Auto-repost settings
  autoRepostEnabled   Boolean        @default(false)
  repostIntervalDays  Int?
  maxReposts          Int?           @default(0)
  repostCount         Int            @default(0)
  nextRepostAt        DateTime?
  parentPostId        String?
  parentPost          ScheduledPost? @relation("PostReposts", fields: [parentPostId], references: [id])
  reposts             ScheduledPost[] @relation("PostReposts")

  // Bulk batch
  bulkBatchId         String?
  bulkBatch           BulkBatch?     @relation(fields: [bulkBatchId], references: [id])

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  accounts            ScheduledPostAccount[]
  publishResults      PostPublishResult[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextRepostAt])
  @@index([bulkBatchId])
}

// Many-to-many: ScheduledPost <-> SocialAccount
model ScheduledPostAccount {
  postId    String
  post      ScheduledPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId String
  account   SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([postId, accountId])
}

// Per-account publish result for a post
model PostPublishResult {
  id              String         @id @default(cuid())
  postId          String
  post            ScheduledPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId       String
  account         SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform        SocialPlatform
  status          PublishStatus  @default(PENDING)
  platformPostId  String?        // ID returned by the platform
  platformUrl     String?        // Public URL of the post
  errorMessage    String?        @db.Text
  attemptCount    Int            @default(0)
  nextRetryAt     DateTime?
  publishedAt     DateTime?
  dismissedAt     DateTime?      // set when user acknowledges a failure
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([postId])
  @@index([accountId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([dismissedAt])
}

// Bulk posting batch
model BulkBatch {
  id              String          @id @default(cuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String          @db.VarChar(255)
  totalPosts      Int             @default(0)
  scheduledPosts  Int             @default(0)
  publishedPosts  Int             @default(0)
  failedPosts     Int             @default(0)
  status          BulkBatchStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  posts           ScheduledPost[]

  @@index([organizationId])
  @@index([status])
}

// Learned optimal posting times per org per platform
model OptimalPostingTime {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform        SocialPlatform
  dayOfWeek       Int            // 0=Sun, 6=Sat
  hour            Int            // 0-23 UTC
  score           Float          @default(0.5) // 0-1 engagement score
  updatedAt       DateTime       @updatedAt

  @@unique([organizationId, platform, dayOfWeek, hour])
  @@index([organizationId, platform])
}

// ============================================================================
// UGC CONTENT GENERATOR - AI Avatar Videos, Voice Cloning, Script-to-Video
// ============================================================================

enum UGCProjectStatus {
  DRAFT
  SCRIPTING
  RENDERING
  READY
  PUBLISHED
  FAILED
}

enum AvatarStyle {
  INFLUENCER
  PROFESSIONAL
  CASUAL
  PRESENTER
  NARRATOR
}

enum AvatarProvider {
  HEYGEN
  DID
  TAVUS
  SYNTHESIA
  MOCK
}

enum VoiceGender {
  MALE
  FEMALE
  NEUTRAL
}

enum RenderStatus {
  QUEUED
  PROCESSING
  COMPLETE
  FAILED
}

// --- UGC Avatar ---------------------------------------------------------------

model UGCAvatar {
  id              String         @id @default(cuid())
  organizationId  String?
  organization    Organization?  @relation("OrgUGCAvatars", fields: [organizationId], references: [id], onDelete: Cascade)

  name            String         @db.VarChar(255)
  description     String?        @db.Text
  style           AvatarStyle    @default(INFLUENCER)
  provider        AvatarProvider @default(HEYGEN)
  externalId      String?        @db.VarChar(255)   // HeyGen/D-ID avatar ID
  thumbnailUrl    String?        @db.Text
  previewVideoUrl String?        @db.Text

  gender          VoiceGender    @default(FEMALE)
  ethnicityHint   String?        @db.VarChar(128)
  ageRange        String?        @db.VarChar(64)    // e.g. "25-35"

  isActive        Boolean        @default(true)
  isSystem        Boolean        @default(false)    // Built-in system avatar

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  projects        UGCProject[]

  @@index([organizationId])
  @@index([style])
  @@index([provider])
  @@index([isSystem])
}

// --- Voice Clone --------------------------------------------------------------

model VoiceClone {
