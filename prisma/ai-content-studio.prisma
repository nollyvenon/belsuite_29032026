// AI Content Studio DB Schema (Prisma)
// Tables: Template, Content, ContentVersion, UsageLog

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // blog, ad, social_post, etc.
  language    String   // ISO code
  prompt      String   // Prompt template
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contents    Content[]
}

model Content {
  id            String   @id @default(cuid())
  templateId    String
  template      Template @relation(fields: [templateId], references: [id])
  userId        String
  language      String
  title         String
  body          String
  metaTags      String[]
  keywords      String[]
  seoScore      Float?
  tone          String?
  style         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  versions      ContentVersion[]
}

model ContentVersion {
  id         String   @id @default(cuid())
  contentId  String
  content    Content  @relation(fields: [contentId], references: [id])
  title      String
  body       String
  createdAt  DateTime @default(now())
  createdBy  String
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  contentId    String?
  templateId   String?
  tokensUsed   Int
  cost         Float
  aiModel      String
  createdAt    DateTime @default(now())
}
