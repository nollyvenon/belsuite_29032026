{
  "name": "belsuite",
  "description": "Production-ready multi-tenant SaaS platform",
  "version": "1.0.0",
  "author": "Belsuite Team",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "next dev -p 3000",
    "dev:backend": "nest start --watch",
    "build": "npm run build:prisma && npm run build:backend && npm run build:frontend",
    "build:prisma": "prisma generate",
    "build:backend": "nest build",
    "build:frontend": "next build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "preinstall": "npm set audit false && npm set fund false"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1021.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "@stripe/stripe-js": "^3.0.0",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.18.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "next": "^16.2.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.4",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "recharts": "^3.8.1",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.1.13",
    "retry": "^0.13.1",
    "rxjs": "^7.8.1",
    "speakeasy": "^2.0.0",
    "stripe": "^14.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/passport-jwt": "^3.0.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@types/zxcvbn": "^4.4.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jest": "^29.7.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
