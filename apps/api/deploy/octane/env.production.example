# --- Laravel Octane (apps/api) — copy relevant keys into server .env ---
APP_ENV=production
APP_DEBUG=false

# Server: swoole | roadrunner | frankenphp
OCTANE_SERVER=swoole
OCTANE_HOST=0.0.0.0
OCTANE_PORT=8080
OCTANE_HTTPS=true

# Workers (integer or "auto")
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=auto
OCTANE_MAX_REQUESTS=500

# PHP memory for each worker process (passed as -dmemory_limit=… to Swoole boot)
OCTANE_PHP_MEMORY_LIMIT=512M

# GC / request limits (see config/octane.php)
OCTANE_GARBAGE_THRESHOLD_MB=48
OCTANE_MAX_EXECUTION_TIME=30

# DB: disconnect between requests (recommended)
OCTANE_DISCONNECT_DATABASE=true

# Monitoring
OCTANE_MONITORING_ENABLED=true
OCTANE_MEMORY_ALERT_MB=384
OCTANE_METRICS_SAMPLE_EVERY_N_OPS=0
OCTANE_MONITORING_LOG_CHANNEL=octane
OCTANE_LOG_LEVEL=info

# Safeguards (slow requests, leak heuristic, hard memory, service recovery)
OCTANE_SAFEGUARDS_ENABLED=true
OCTANE_SLOW_REQUEST_MS=2000
OCTANE_MEMORY_HARD_STOP_MB=512
OCTANE_MEMORY_LEAK_DELTA_MB=5
OCTANE_MEMORY_LEAK_STREAK=20
OCTANE_RESTART_ON_HARD_MEMORY=true
OCTANE_RESTART_ON_LEAK_PATTERN=true
OCTANE_RECOVER_DB_ON_REQUEST=true
OCTANE_RECOVER_REDIS_ON_REQUEST=false

# Logs: add octane to stack for file + optional Slack on critical
# LOG_STACK=single,slack

# --- Cache / session (Octane: avoid file-based shared state across replicas) ---
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default

# --- Queues (run queue:work in separate Supervisor programs, not inside Octane) ---
QUEUE_CONNECTION=redis
QUEUE_AFTER_COMMIT=true
# REDIS_QUEUE_BLOCK_FOR=5

# --- Nest strangler (Phase 6 staging: set NEST_FALLBACK_ENABLED=false after parity) ---
NEST_BACKEND_URL=http://nest-internal:3001
NEST_FALLBACK_ENABLED=true
NEST_DEPRECATION_READY=false
